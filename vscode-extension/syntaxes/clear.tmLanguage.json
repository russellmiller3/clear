{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Clear",
  "scopeName": "source.clear",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#section-headers" },
    { "include": "#component-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.clear",
          "match": "#.*$"
        },
        {
          "name": "comment.block.clear",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.clear",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.clear",
              "match": "\\\\."
            },
            {
              "name": "meta.embedded.expression.clear",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                { "include": "#identifiers" },
                { "include": "#operators" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.clear",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.declaration.clear",
          "match": "\\b(build|for|connect|to|database|theme|use|everything|from|define|component|function|table|page|section|agent|skill)\\b"
        },
        {
          "name": "keyword.control.flow.clear",
          "match": "\\b(if|otherwise|else|when|for each|while|repeat|times|max|return|send|back|save|as|a|an|the|in|on|by|at)\\b"
        },
        {
          "name": "keyword.operator.assignment.clear",
          "match": "\\b(is|are|=)\\b"
        },
        {
          "name": "support.function.builtin.clear",
          "match": "\\b(show|display|heading|subheading|text|small|bold|italic|button|input|dropdown|checkbox|chart|divider|image|link|video|audio|table|cards|list|gallery|map|calendar|qr)\\b"
        },
        {
          "name": "support.type.clear",
          "match": "\\b(integer|number|text|boolean|date|email|url|password|json)\\b"
        },
        {
          "name": "keyword.control.relation.clear",
          "match": "\\b(belongs to|has many|has one|unique|required|optional)\\b"
        },
        {
          "name": "keyword.other.auth.clear",
          "match": "\\b(needs login|requires login|current user|caller)\\b"
        },
        {
          "name": "keyword.other.ai.clear",
          "match": "\\b(ask claude|knows about|remember conversation|can use|must not|tools|skills)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.possessive.clear",
          "match": "'s\\b"
        },
        {
          "name": "keyword.operator.arithmetic.clear",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.comparison.clear",
          "match": "==|!=|<=|>=|<|>"
        }
      ]
    },
    "section-headers": {
      "patterns": [
        {
          "name": "entity.name.section.clear",
          "match": "^\\s*(page|section|table|define\\s+component|define\\s+function|define\\s+agent)\\s+([A-Za-z'][A-Za-z0-9_' ]*)",
          "captures": {
            "1": { "name": "keyword.control.declaration.clear" },
            "2": { "name": "entity.name.type.clear" }
          }
        }
      ]
    },
    "component-call": {
      "patterns": [
        {
          "name": "meta.component-call.clear",
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.component.clear" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.clear",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
