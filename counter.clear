/*
DATAFLOW:
  GET /api/count    → read Counter table → { count: N }
  POST /api/increment → read Counter, +1, save → { count: N+1 }
  POST /api/reset   → read Counter, set 0, save → { count: 0 }

NOTE: avoid `is empty` on lists — compiles to `== null` and never matches
an empty array. Use `length of X is 0` instead.
*/

build for javascript backend
database is local memory

create a Counter table:
  value (number), default 0

when user calls GET /api/count:
  counters = get all Counter
  row_count = length of counters
  if row_count is 0:
    fresh_counter = { value: 0 }
    saved = save fresh_counter to Counter
    send back { count: saved's value }
  otherwise:
    row = first of counters
    send back { count: row's value }

when user calls POST /api/increment:
  counters = get all Counter
  row_count = length of counters
  if row_count is 0:
    fresh_counter = { value: 1 }
    saved = save fresh_counter to Counter
    send back { count: saved's value }
  otherwise:
    row = first of counters
    next_value = row's value + 1
    row's value = next_value
    result = save row to Counter
    send back { count: result's value }

when user calls POST /api/reset:
  counters = get all Counter
  row_count = length of counters
  if row_count is 0:
    fresh_counter = { value: 0 }
    saved = save fresh_counter to Counter
    send back { count: 0 }
  otherwise:
    row = first of counters
    row's value = 0
    result = save row to Counter
    send back { count: 0 }
