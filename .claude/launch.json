{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "playground",
      "runtimeExecutable": "node",
      "runtimeArgs": ["playground/server.js"],
      "port": 3456,
      "autoPort": false,
      "env": { "CLEAR_ALLOW_SEED": "1" }
    },
    {
      "name": "playground-dev",
      "runtimeExecutable": "node",
      "runtimeArgs": ["playground/server.js", "--port=3488", "--session-id=dev"],
      "port": 3488,
      "autoPort": false
    },
    {
      "name": "startup-landing",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--input-type=module", "--eval", "import{compileProgram}from'./index.js';import fs from'fs';import http from'http';const r=compileProgram(fs.readFileSync('apps/startup-landing/main.clear','utf8'));const s=http.createServer((_,res)=>{res.writeHead(200,{'Content-Type':'text/html;charset=utf-8'});res.end(r.html||'');});s.listen(5001,()=>console.log('ready'));"],
      "port": 5001,
      "autoPort": false
    },
    {
      "name": "saas-landing",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--input-type=module", "--eval", "import{compileProgram}from'./index.js';import fs from'fs';import http from'http';const r=compileProgram(fs.readFileSync('apps/saas-landing/main.clear','utf8'));const s=http.createServer((_,res)=>{res.writeHead(200,{'Content-Type':'text/html;charset=utf-8'});res.end(r.html||'');});s.listen(5002,()=>console.log('ready'));"],
      "port": 5002,
      "autoPort": false
    },
    {
      "name": "store-ops",
      "runtimeExecutable": "node",
      "runtimeArgs": ["apps/store-ops/server.js"],
      "port": 4031,
      "autoPort": false
    },
    {
      "name": "landing-apps",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "landing", "-p", "5010"],
      "port": 5010,
      "autoPort": false
    },
    {
      "name": "devtool-landing",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--input-type=module", "--eval", "import{compileProgram}from'./index.js';import fs from'fs';import http from'http';const r=compileProgram(fs.readFileSync('apps/devtool-landing/main.clear','utf8'));const s=http.createServer((_,res)=>{res.writeHead(200,{'Content-Type':'text/html;charset=utf-8'});res.end(r.html||'');});s.listen(5003,()=>console.log('ready'));"],
      "port": 5003,
      "autoPort": false
    },
    {
      "name": "marcus-deal-desk",
      "runtimeExecutable": "node",
      "runtimeArgs": ["apps/deal-desk/server.js"],
      "port": 4101,
      "autoPort": false,
      "env": { "PORT": "4101" }
    },
    {
      "name": "marcus-approval-queue",
      "runtimeExecutable": "node",
      "runtimeArgs": ["apps/approval-queue/server.js"],
      "port": 4102,
      "autoPort": false,
      "env": { "PORT": "4102" }
    },
    {
      "name": "marcus-lead-router",
      "runtimeExecutable": "node",
      "runtimeArgs": ["apps/lead-router/server.js"],
      "port": 4103,
      "autoPort": false,
      "env": { "PORT": "4103" }
    },
    {
      "name": "marcus-onboarding-tracker",
      "runtimeExecutable": "node",
      "runtimeArgs": ["apps/onboarding-tracker/server.js"],
      "port": 4104,
      "autoPort": false,
      "env": { "PORT": "4104" }
    },
    {
      "name": "marcus-internal-request-queue",
      "runtimeExecutable": "node",
      "runtimeArgs": ["apps/internal-request-queue/server.js"],
      "port": 4105,
      "autoPort": false,
      "env": { "PORT": "4105" }
    },
    {
      "name": "marcus-support-triage",
      "runtimeExecutable": "node",
      "runtimeArgs": ["apps/support-triage/server.js"],
      "port": 4106,
      "autoPort": false,
      "env": { "PORT": "4106" }
    },
    {
      "name": "studio-builder-mode",
      "runtimeExecutable": "node",
      "runtimeArgs": ["playground/server.js"],
      "port": 4200,
      "autoPort": false,
      "env": { "PORT": "4200", "CLEAR_ALLOW_SEED": "1" }
    }
  ]
}
