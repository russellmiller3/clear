build for javascript backend
database is local memory

create a Conferences table:
  title, required
  capacity (number), required
  registered_count (number), default 0

create a Attendees table:
  conference_id, required
  name, required
  email, required

when user calls POST /api/attendees sending attendee:
  needs login
  conference = look up Conference where id is attendee's conference_id
  check conference's registered_count is less than conference's capacity, otherwise error 'Conference is full'
  new_attendee = save attendee as new Attendee
  conference's registered_count = conference's registered_count + 1
  save conference to Conferences
  send back new_attendee

when user calls POST /api/seed:
  create c1:
    title is 'ClearConf 2026'
    capacity = 2
    registered_count = 2
  save c1 as new Conference
  send back 'seeded'
