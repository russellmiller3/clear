.env
node_modules/
package-lock.json
# Size-guard test fixtures — generated at test time, not committed
test-fixtures/knows-about-large/
apps/*/build/package.json
apps/*/build/package-lock.json
apps/*/build/node_modules/
apps/*/build/clear-data.json
apps/*/build/clear-data.db
apps/*/build/clear-data.db-wal
apps/*/build/clear-data.db-shm
clear-data.json
clear-data.db
clear-data.db-wal
clear-data.db-shm
.clear-test-runner.*
playground/.playground-build/
test-save/
test-save-compiled/
.clear-test-build/
.clear-test-runner.cjs
.clear-test-server.cjs
.tmp/

# Build artifacts — regenerated from canonical runtime/ on every clear build
# Canonical sources live in runtime/. These per-app copies are output, not source.
clear-runtime/
apps/*/clear-runtime/
apps/*/build/clear-runtime/
.clear-build/
.clear-serve/
tests/*/build/clear-runtime/
tests/guard-bugs/*/build/clear-runtime/
.claude/.hook-proposal-stamp
.claude/.cookbook-updater-stamp
.claude/.propose-new-tools-stamp

# CF-1 — runtime instrumentation beacon log (per-dev, regenerates on demand)
playground/flywheel-beacons.jsonl

# Background-agent worktrees — created on demand, not source code
.claude/worktrees/
.claude/scheduled_tasks.lock

# Meph / sweep artifacts — generated by local runs, not source code
.meph-build/
playground/sessions/

# Scratch apps and compiled app outputs from compiler/sweep experiments
*-build/
*-out/
temp-*/
temp-*.clear
temp-*.js
temp-*.cjs
tmp-*.clear
tmp-*.mjs
tmp-*.py
test-*.clear
/test-*.js
/*-api.clear
/*-server.clear
/*-task.clear
/task-*.clear
/app.clear
/counter.clear
/server.js
/test.js
/check-env.js
/debug-*.js
/debug-*.mjs

# Python cache artifacts
__pycache__/
*.pyc
.claude/state/
.clear-uat-screenshots/
