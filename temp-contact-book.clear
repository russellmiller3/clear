/*
  Contact Book — backend-only CRUD
  ─────────────────────────────────
  TABLE       Contacts (name, email, phone, notes)
  ENDPOINTS   POST   /api/contacts          create one
              GET    /api/contacts          list all
              GET    /api/contacts/:id      look up one
              PUT    /api/contacts/:id      update one
              DELETE /api/contacts/:id      remove one
  RULES       email column must be a real email and unique
              (validates and de-dupes automatically)
*/

build for javascript backend

# Data

create a Contacts table:
  name, required
  email, required, unique, email
  phone
  notes

# Backend

when user sends contact to /api/contacts:
  saved = save contact as new Contacts
  send back saved with status 201

when user calls GET /api/contacts:
  send back all Contacts

when user calls GET /api/contacts/:id:
  send back the Contact with this id

when user calls PUT /api/contacts/:id sending changes:
  save changes to Contacts
  send back changes

when user calls DELETE /api/contacts/:id:
  delete Contact with this id
  send back 'ok' with status 204
