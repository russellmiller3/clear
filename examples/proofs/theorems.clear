# Universal theorems — provable correctness demo (#4 / flagship).
#
# These tests don't pin down specific input numbers — they use FREE
# variables. The prover sees the variables aren't bound, switches into
# symbolic mode, and proves the claim holds for ALL possible inputs.
#
# This is the difference between "tested for these examples" and
# "mathematically true forever" — the moonshot claim made real.
#
# Run: clear prove examples/proofs/theorems.clear

define function add(a is number, b is number):
  return a + b

define function multiply(a is number, b is number):
  return a * b

define function identity(x):
  return x

define function double(x is number):
  return x * 2

define function triple(x is number):
  return x * 3


# ---------------------------------------------------------------------------
# Universal theorems — variables are free, so claims must hold for ANY input.
# ---------------------------------------------------------------------------

test 'addition is commutative for any inputs':
  expect add(a, b) is add(b, a)

test 'multiplication is commutative for any inputs':
  expect multiply(a, b) is multiply(b, a)

test 'addition is associative for any inputs':
  expect add(add(a, b), c) is add(a, add(b, c))

test 'adding zero leaves a number unchanged':
  expect add(x, 0) is x

test 'multiplying by 1 leaves a number unchanged':
  expect multiply(x, 1) is x

test 'multiplying by 0 always gives 0':
  expect multiply(x, 0) is 0

test 'identity returns its input':
  expect identity(y) is y

# ---------------------------------------------------------------------------
# Distributivity / like-term collection (PC-1)
# ---------------------------------------------------------------------------

test 'doubling is the same as adding to itself':
  expect double(x) is add(x, x)

test 'tripling is the same as adding three copies':
  expect triple(x) is add(add(x, x), x)

test 'doubling then doubling is multiplying by 4':
  expect double(double(x)) is multiply(x, 4)

# ---------------------------------------------------------------------------
# Conditional handling (PC-2)
# A function with an `if/then` whose both branches reduce to the same value
# is provable for ANY input — even when the input controls which branch fires.
# ---------------------------------------------------------------------------

define function constant_either_way(flag):
  if flag:
    return 42
  otherwise:
    return 42

define function double_either_way(x is number, flag):
  if flag:
    return x + x
  otherwise:
    return x * 2

test 'a constant function returns the same value regardless of branch':
  expect constant_either_way(flag) is 42

test 'two branches that compute the same thing in different forms still match':
  expect double_either_way(x, flag) is multiply(x, 2)
