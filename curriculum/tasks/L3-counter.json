      "path": "/api/count",
      "expect": { "status": 200, "bodyHas": ["count"] }
    },
    {
      "method": "POST",
      "path": "/api/increment",
      "expect": { "status": 200, "bodyHas": ["count"] }
    },
    {
      "method": "POST",
      "path": "/api/increment",
      "expect": { "status": 200, "bodyHas": ["count"] }
    },
    {
      "method": "GET",
      "path": "/api/count",
      "expect": { "status": 200, "bodyHas": ["count"] }
    }
  ]
}
