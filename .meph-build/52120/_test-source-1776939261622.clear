build for web and javascript backend
database is local memory

create a Requests table:
  title, required
  description
  amount (number), default 0
  status, default 'pending'

allow signup and login
owner is 'admin@example.com'

when user sends request_data to /api/requests:
  validate request_data:
    title is required
  saved = save request_data to Requests
  send back saved with status 201

when user calls GET /api/requests:
  requests = get all Requests
  send back requests

when user calls GET /api/requests/pending:
  pending = get all Requests where status is 'pending'
  send back pending

when user calls PUT /api/requests/:id sending changes:
  requires login
  save changes to Requests with this id
  send back 'updated' with success message

page 'Submit Request' at '/':
  section 'Submit a Request' with style page_section:
    'Title' as text input
    'Description' as text area
    'Amount' as number input
    button 'Submit':
      send title and description and amount as a new record to '/api/requests'

page 'Approval Queue' at '/approvals':
  on page load get requests from '/api/requests'
  section 'All Requests' with style page_section:
    display requests as table
