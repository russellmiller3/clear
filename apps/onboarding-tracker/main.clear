/*
LAYOUT:
+-------------+---------------------------------------------+
| Sidebar     | Header                                      |
| Queue links +---------------------------------------------+
|             | Page header + KPI strip                     |
|             | Customer table + row detail panel           |
|             | New-customer form + step table              |
+-------------+---------------------------------------------+

DATAFLOW:
Browser --> /api/seed --> Customers + OnboardingSteps
Browser --> /api/customers/onboarding --> customer queue
Browser --> /api/steps --> checklist table
Browser --> /api/customers --> create or update customers
*/

build for web and javascript backend
database is local memory

# Database

create a Customers table:
  name, required
  company, required
  email
  status, default 'onboarding'
  started_at_date, auto
  account_manager
  notes
  the customer's creator can read, change, or delete
  any admin can read

# Customer-success queue
/*
Auto-generates audit, notification queue, and action URLs. Each action
records who acted, when, and where declared, queues an email to the customer.
*/

queue for customer:
  reviewer is 'success_manager'
  actions: mark active, escalate, email
  email customer when mark active

create a OnboardingSteps table:
  customer_id, required
  step_name, required
  completed, default false
  completed_at_date
  customer belongs to Customers
  the step's creator can read, change, or delete
  any admin can read

# Backend

## Middleware

allow cross-origin requests
allow signup and login
log every request

## Endpoints

when user requests data from /api/customers:
  send back all Customers

when user requests data from /api/customers/onboarding:
  send back all Customers where status is 'onboarding'

when user sends customer to /api/customers:
  requires login
  validate customer:
    name is text, required
    company is text, required
  new_customer = save customer as new Customer
  send back new_customer with success message

when user updates customer at /api/customers/:id:
  requires login
  save customer to Customers
  send back 'updated' with success message

when user requests data from /api/steps:
  send back all OnboardingSteps

when user sends step to /api/steps:
  requires login
  new_step = save step as new OnboardingStep
  send back new_step with success message

when user updates step at /api/steps/:id:
  requires login
  save step to OnboardingSteps
  send back 'updated' with success message

## Seed Data

when user sends seed to /api/seed:
  create c1:
    name is 'Priya Shah'
    company is 'Acme Corp'
    email is 'priya@acmecorp.com'
    status is 'onboarding'
    account_manager is 'sarah.j'
  save c1 as new Customer
  create c2:
    name is 'Marcus Jones'
    company is 'Shopify Shops'
    email is 'mj@shopify-shops.com'
    status is 'onboarding'
    account_manager is 'mike.l'
  save c2 as new Customer
  create c3:
    name is 'Jenna Liu'
    company is 'Tiny Studio'
    email is 'jenna@tinystudio.co'
    status is 'active'
    account_manager is 'sarah.j'
  save c3 as new Customer
  create s1:
    customer_id is c1's id
    step_name is 'Kickoff call'
    completed is true
  save s1 as new OnboardingStep
  create s2:
    customer_id is c1's id
    step_name is 'Technical setup'
    completed is true
  save s2 as new OnboardingStep
  create s3:
    customer_id is c1's id
    step_name is 'First campaign launched'
    completed is false
  save s3 as new OnboardingStep
  create s4:
    customer_id is c2's id
    step_name is 'Kickoff call'
    completed is true
  save s4 as new OnboardingStep
  create s5:
    customer_id is c2's id
    step_name is 'Technical setup'
    completed is false
  save s5 as new OnboardingStep
  send back 'seeded' with success message

# Frontend

page 'Onboarding Tracker' at '/':
  on page load:
    send nothing to '/api/seed'
    get customers from '/api/customers/onboarding'
    get steps from '/api/steps'

  total = count of customers
  step_total = count of steps

  section 'Layout' with style app_layout:

    section 'Sidebar' with style app_sidebar:
      heading 'Onboarding'

      nav section 'Queue':
        nav item 'Dashboard' to '/' with count total with icon 'layout-dashboard'
        nav item 'Customers' to '/customers' with count total with icon 'users'
        nav item 'Steps' to '/steps' with count step_total with icon 'list-checks'

      nav section 'Team':
        nav item 'Managers' to '/managers' with icon 'user-check'

    section 'Main' with style app_main:

      section 'Header' with style app_header:
        heading 'Customer Success'
        text 'Onboarding command center'

      section 'Content' with style app_content:

        page header 'Customer Onboarding':
          subtitle 'Active setup queue for new accounts'
          actions:
            button 'Refresh':
              get customers from '/api/customers/onboarding'
              get steps from '/api/steps'

        stat strip:
          stat card 'Active Customers':
            value total
            delta '+2 this week'
            sparkline [2, 3, 3, 4, 5]
            icon 'users'
          stat card 'Open Steps':
            value step_total
            delta '-1 overdue'
            sparkline [6, 6, 5, 5, 4]
            icon 'list-checks'
          stat card 'Managers':
            value 2
            delta 'Sarah and Mike'
            sparkline [1, 1, 2, 2, 2]
            icon 'user-check'

        text '{total} customers actively onboarding'

        section 'Customer Workbench' as 2 columns:
          section 'Customers' with style app_table:
            display customers as table showing company, name, account_manager, status

          detail panel for selected_customer:
            text selected_customer's company
            text selected_customer's name
            text selected_customer's email
            text selected_customer's account_manager
            text selected_customer's status
            actions:
              button 'Mark Active':
                change selected_customer's status from 'onboarding' to 'active'
                update selected_customer at /api/customers/:id/mark-active
                get customers from '/api/customers/onboarding'
              button 'Escalate':
                change selected_customer's status from 'onboarding' to 'escalated'
                update selected_customer at /api/customers/:id/escalate
                get customers from '/api/customers/onboarding'
              button 'Email':
                change selected_customer's status from 'onboarding' to 'email'
                update selected_customer at /api/customers/:id/email
                get customers from '/api/customers/onboarding'

        section 'New Customer' with style app_card:
          heading 'New Customer'
          'Customer name' as text input saves to name
          'Company' as text input saves to company
          'Email' as text input saves to email
          'Account manager' as text input saves to account_manager
          button 'Add Customer':
            send name, company, email, and account_manager to '/api/customers'
            get customers from '/api/customers/onboarding'
            name is ''
            company is ''

        section 'All Steps' with style app_table:
          display steps as table showing customer_id, step_name, completed

page 'Customers' at '/customers':
  on page load:
    get customers from '/api/customers/onboarding'

  total = count of customers

  section 'Layout' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      heading 'Onboarding'
      nav section 'Queue':
        nav item 'Dashboard' to '/' with icon 'layout-dashboard'
        nav item 'Customers' to '/customers' with count total with icon 'users'
        nav item 'Steps' to '/steps' with icon 'list-checks'
      nav section 'Team':
        nav item 'Managers' to '/managers' with icon 'user-check'

    section 'Main' with style app_main:
      section 'Header' with style app_header:
        heading 'Customers'
        text 'Onboarding / Customers'

      section 'Content' with style app_content:
        page header 'All onboarding customers':
          subtitle '{total} customers in the onboarding queue'

        section 'Customers' with style app_table:
          display customers as table showing company, name, email, account_manager, status

page 'Steps' at '/steps':
  on page load:
    get steps from '/api/steps'

  step_total = count of steps
  open_steps = count of steps where completed is false
  done_steps = count of steps where completed is true

  section 'Layout' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      heading 'Onboarding'
      nav section 'Queue':
        nav item 'Dashboard' to '/' with icon 'layout-dashboard'
        nav item 'Customers' to '/customers' with icon 'users'
        nav item 'Steps' to '/steps' with count step_total with icon 'list-checks'
      nav section 'Team':
        nav item 'Managers' to '/managers' with icon 'user-check'

    section 'Main' with style app_main:
      section 'Header' with style app_header:
        heading 'Steps'
        text 'Onboarding / Steps'

      section 'Content' with style app_content:
        page header 'Onboarding steps':
          subtitle '{step_total} steps total — {open_steps} open, {done_steps} completed'

        stat strip:
          stat card 'Open':
            value open_steps
            icon 'circle-dashed'
          stat card 'Done':
            value done_steps
            icon 'check-circle-2'

        section 'All steps' with style app_table:
          display steps as table showing customer_id, step_name, completed

page 'Managers' at '/managers':
  on page load:
    get customers from '/api/customers/onboarding'

  sarah_customers = count of customers where account_manager is 'Sarah'
  mike_customers = count of customers where account_manager is 'Mike'

  section 'Layout' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      heading 'Onboarding'
      nav section 'Queue':
        nav item 'Dashboard' to '/' with icon 'layout-dashboard'
        nav item 'Customers' to '/customers' with icon 'users'
        nav item 'Steps' to '/steps' with icon 'list-checks'
      nav section 'Team':
        nav item 'Managers' to '/managers' with icon 'user-check'

    section 'Main' with style app_main:
      section 'Header' with style app_header:
        heading 'Managers'
        text 'Onboarding / Team'

      section 'Content' with style app_content:
        page header 'Account managers':
          subtitle 'Two managers split the onboarding queue.'

        stat strip:
          stat card 'Sarah':
            value sarah_customers
            delta 'Active customers'
            icon 'user-check'
          stat card 'Mike':
            value mike_customers
            delta 'Active customers'
            icon 'user-check'

        section 'Customers by manager' with style app_table:
          display customers as table showing account_manager, company, name, status

