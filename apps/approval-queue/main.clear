/*
LAYOUT:
+----------------+-----------------------------------------------+
| Approval Queue | Header: intake workspace                       |
|                +-----------------------------------------------+
| Queues         | Pending approvals + KPI strip                  |
| - Pending      | +-------------------------+ +---------------+ |
| - All requests | | pending table           | | detail panel  | |
|                | | requester / amount      | | decision view | |
|                | +-------------------------+ +---------------+ |
|                | Submit request form                           |
+----------------+-----------------------------------------------+

DATAFLOW:
Submitter -> POST /api/requests -> Requests table
Approver  -> GET /api/requests/pending -> table -> detail panel
Approver  -> PUT /api/requests/:id -> approved or rejected
*/

build for web and javascript backend
database is local memory

# Database

create a Requests table:
  title, required
  description
  amount (number), default 0
  status, default 'pending'
  notes
  requester
  created_at_date, auto

# Approval queue — auto-generates audit table, notification queue,
# filtered URL, and PUT URLs for each action. Each PUT requires login.

queue for request:
  reviewer is 'approver'
  actions: approve, reject

# Backend

## Middleware

allow cross-origin requests
allow signup and login
log every request

## Endpoints

when user requests data from /api/requests:
  send back all Requests

when user requests data from /api/requests/pending:
  send back all Requests where status is 'pending'

when user sends request to /api/requests:
  validate request:
    title is text, required, min 1, max 200
    amount is number, min 0
  new_request = save request as new Request
  send back new_request with success message

when user updates request at /api/requests/:id:
  requires login
  save request to Requests
  send back 'updated' with success message

## Seed Data

when user sends seed to /api/seed:
  create r1:
    title is 'Quarterly software budget - Acme Corp'
    description is 'Standard renewal, 15 seats'
    amount is 4500
    status is 'pending'
    requester is 'sarah.j'
  save r1 as new Request
  create r2:
    title is 'Travel expenses - sales conference'
    description is 'Airfare and hotel for 2 reps'
    amount is 2800
    status is 'pending'
    requester is 'mike.l'
  save r2 as new Request
  create r3:
    title is 'Contractor engagement - design'
    description is 'Design contractor, 3 months'
    amount is 18000
    status is 'pending'
    requester is 'alex.p'
  save r3 as new Request
  create r4:
    title is 'New office chairs'
    description is 'Ergonomic chairs for 8 desks'
    amount is 2400
    status is 'approved'
    requester is 'jamie.k'
  save r4 as new Request
  create r5:
    title is 'Expired credit card'
    description is 'Card expired last week, need replacement'
    amount is 0
    status is 'rejected'
    requester is 'taylor.w'
  save r5 as new Request
  send back 'seeded' with success message

# Frontend

page 'Approval Queue' at '/':
  pending is an empty list
  all_requests is an empty list

  on page load:
    send nothing to '/api/seed'
    get pending from '/api/requests/pending'
    get all_requests from '/api/requests'

  pending_count = count of pending
  all_count = count of all_requests
  pending_amount = sum of amount in pending

  section 'App' with style app_layout:

    section 'Sidebar' with style app_sidebar:
      heading 'Approvals'

      nav section 'Queues':
        nav item 'Pending' to '/' with count pending_count with icon 'inbox'
        nav item 'All requests' to '/' with count all_count with icon 'list-checks'

    section 'Main' with style app_main:

      section 'Top' with style app_header:
        heading 'Approval Queue'
        text 'Operations / Request approvals'
        button 'Refresh':
          get pending from '/api/requests/pending'
          get all_requests from '/api/requests'

      section 'Body' with style app_content:

        page header 'Pending Approvals':
          subtitle '{pending_count} requests need a decision'
          actions:
            button 'Refresh':
              get pending from '/api/requests/pending'
              get all_requests from '/api/requests'

        stat strip:
          stat card 'Pending':
            value pending_count
            delta 'Awaiting approver'
            sparkline [3, 4, 5, 4, 3]
            icon 'inbox'
          stat card 'Requested Amount':
            value pending_amount
            delta 'Open request value'
            sparkline [6, 7, 8, 6, 9]
            icon 'dollar-sign'
          stat card 'All Requests':
            value all_count
            delta 'Across every status'
            sparkline [2, 3, 4, 5, 5]
            icon 'list-checks'

        section 'Review Workbench' as 2 columns:
          section 'Pending Requests' with style app_table:
            display pending as table showing title, requester, amount, status

          detail panel for selected_request:
            small text 'Select a request to inspect it.'
            text selected_request's title
            text selected_request's description
            display selected_request's amount as dollars called 'Amount'
            text selected_request's requester
            text selected_request's status
            actions:
              button 'Approve':
                show toast 'Sign in to approve this request'
              button 'Reject':
                show toast 'Sign in to reject this request'

        section 'New Request' with style app_card:
          subheading 'Submit Request'
          'Title' as text input saves to title
          'Description' as text input saves to description
          'Amount ($)' as number input saves to amount
          'Requester' as text input saves to requester
          button 'Submit':
            send title, description, amount, and requester to '/api/requests'
            get pending from '/api/requests/pending'
            get all_requests from '/api/requests'
            title is ''
            description is ''
            amount is 0

# Tests

test:
  can user submit a request with title is 'Budget approval', amount is 500
  expect it succeeds
  expect response has id

test:
  updating a request should require login
