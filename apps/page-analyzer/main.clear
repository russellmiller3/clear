build for javascript backend

database is local memory

create a Pages table:
  url, required
  title
  link_count (number), default 0
  analyzed_at_date, auto

agent 'Page Analyzer' receives subject:
  guard subject's url is not nothing or 'URL is required'
  subject's title is 'Analyzed'
  subject's link_count is 42
  send back subject

when user calls POST /api/analyze sending subject:
  requires login
  validate subject:
    url is text, required
  analyzed = call 'Page Analyzer' with subject
  saved = save analyzed as new Page
  send back saved with success message

when user calls GET /api/pages:
  all_pages = get all Pages
  send back all_pages

when user calls GET /api/health:
  send back 'ok'
