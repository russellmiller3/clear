# Project Tracker — issue management app using semantic style tokens
build for web and javascript backend

theme 'midnight'

# ── Database ──────────────────────────────────────────────────────────────────

database is local memory

create a Projects table:
  name, required
  status, default 'active'
  color, default 'blue'

create an Issues table:
  title, required
  project, required
  assignee
  priority, default 'medium'
  status, default 'backlog'
  created_at_date, auto

# ── Backend ───────────────────────────────────────────────────────────────────

allow cross-origin requests
log every request

when user calls GET /api/projects:
  all_projects = get all Projects
  send back all_projects

when user calls POST /api/projects sending project_data:
  validate project_data:
    name is text, required, min 1, max 80
  new_project = save project_data as new Project
  send back new_project

when user calls GET /api/issues:
  all_issues = get all Issues
  send back all_issues


when user calls POST /api/issues sending issue_data:
  validate issue_data:
    title is text, required, min 1, max 200
    project is text, required
  new_issue = save issue_data as new Issue
  send back new_issue

when user calls DELETE /api/issues/:id:
  requires auth
  delete the Issue with this id
  send back 'deleted'

# ── Styles ────────────────────────────────────────────────────────────────────
# Every style here uses ONLY semantic tokens — no raw CSS values.


# ── Frontend ──────────────────────────────────────────────────────────────────

page 'Project Tracker' at '/':

  open_count = 12
  in_progress_count = 5
  done_count = 23
  all_issues = []

  on page load:
    all_issues = GET '/api/issues'

  section 'App' with style app_layout:

    section 'Sidebar' with style app_sidebar, 208px wide:

      heading 'Tracker'

      section 'Workspace Nav':
        text 'My Issues'
        text 'All Projects'
        text 'Inbox'

      section 'Projects':
        text 'Frontend'
        text 'Backend'
        text 'Design'
        text 'DevOps'

      section 'Views':
        text 'Active sprints'
        text 'Roadmap'
        text 'Archive'

    section 'Main' fills remaining space, stacked:

      section 'Header' with style app_header:
        heading 'Issues'
        button 'New Issue':
          show 'New Issue'

      section 'Content' with style app_content:

        section 'Stats Row' as 4 columns:
          section 'Open' with style metric_card:
            small text 'Open'
            heading '12'
            text '+3 this week'
          section 'In Progress' with style metric_card:
            small text 'In Progress'
            heading '5'
            text '2 assigned to you'
          section 'Done' with style metric_card:
            small text 'Done this week'
            heading '23'
            text '+8 vs last week'
          section 'Team' with style metric_card:
            small text 'Team members'
            heading '8'
            text '6 active today'

        section 'Issues Table' with style app_table:
          display all_issues as table showing title, project, priority, status with delete

        section 'Recent Activity' with style app_list:
          heading 'Recent Activity'
          section 'Activity 1':
            text 'Fix auth token expiry on mobile'
            badge 'High' as error
          section 'Activity 2':
            text 'Update onboarding flow copy'
            badge 'Medium' as warning
          section 'Activity 3':
            text 'Dashboard chart not loading in Safari'
            badge 'High' as error
          section 'Activity 4':
            text 'Add CSV export to reports page'
            badge 'Low' as neutral

        section 'Empty Section' with style empty_state:
          heading 'No archived issues'
          text 'Issues you archive will appear here.'
          button 'View all issues':
            do nothing

        section 'New Issue' as modal:
          section 'Form' with style form:
            subheading 'New Issue'
            'Title' as text input saves to new_title
            'Project' as dropdown with ['Frontend', 'Backend', 'Design', 'DevOps'] saves to new_project
            'Priority' as dropdown with ['Low', 'Medium', 'High', 'Critical'] saves to new_priority
            button 'Create Issue':
              new_issue_data = collect new_title, new_project, new_priority
              POST new_issue_data to '/api/issues'
              all_issues = GET '/api/issues'
              hide 'New Issue'
            button 'Cancel':
              hide 'New Issue'
