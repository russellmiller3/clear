# ── Frontend ──────────────────────────────────────────────────────────────────

page 'Project Tracker' at '/':

  all_issues = []

  on page load:
    send nothing to '/api/seed'
    get all_issues from '/api/issues'

  section 'App' with style app_layout:

    section 'Sidebar' with style app_sidebar:

      heading 'Tracker'

      section 'Workspace':
        text 'My Issues'
        text 'All Projects'
        text 'Inbox'

      section 'Projects':
        text 'Frontend'
        text 'Backend'
        text 'Design'
        text 'DevOps'

      section 'Views':
        text 'Active sprints'
        text 'Roadmap'
        text 'Archive'

    section 'Main' fills remaining space, stacked:

      section 'Header' with style app_header:
        heading 'Issues'
        button 'New Issue':
          show 'New Issue'

      section 'Content' with style app_content:

        section 'Stats Row' as 4 columns:
          section 'Open' with style metric_card:
            small text 'Open'
            heading '12'
            text '+3 this week'
          section 'In Progress' with style metric_card:
            small text 'In Progress'
            heading '5'
            text '2 assigned to you'
          section 'Done' with style metric_card:
            small text 'Done'
            heading '23'
            text '+8 vs last week'
          section 'Team' with style metric_card:
            small text 'Team'
            heading '8'
            text '6 active today'

        section 'Issues Table' with style app_table:
          display all_issues as table showing title, project, assignee, priority, status with delete

        section 'Recent Activity' with style app_list:
          heading 'Recent Activity'
          section 'A1':
            text 'Sarah Chen moved "Fix auth token expiry" to In Progress'
            badge 'just now' as info
          section 'A2':
            text 'Marcus Lee commented on "Update onboarding flow"'
            badge '2m ago' as neutral
          section 'A3':
            text 'Alex Rivera closed "Set up CI pipeline for staging"'
            badge '15m ago' as success
          section 'A4':
            text 'Jenna Park created "Add dark mode toggle to settings"'
            badge '1h ago' as neutral
          section 'A5':
            text 'Sarah Chen resolved "Migrate user sessions to Redis"'
            badge '3h ago' as success

        section 'New Issue' as modal:
          section 'Form' with style form:
            subheading 'New Issue'
            'Title' as text input saves to new_title
            'Project' as dropdown with ['Frontend', 'Backend', 'Design', 'DevOps'] saves to new_project
            'Assignee' as text input saves to new_assignee
            'Priority' as dropdown with ['Low', 'Medium', 'High', 'Critical'] saves to new_priority
            button 'Create Issue':
              new_issue_data = collect new_title, new_project, new_assignee, new_priority
              send new_issue_data to '/api/issues'
              get all_issues from '/api/issues'
              hide 'New Issue'
            button 'Cancel':
              hide 'New Issue'
