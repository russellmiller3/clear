# Project Tracker — reference dashboard for app UI presets
build for web and javascript backend

theme 'ivory'

# ── Database ──────────────────────────────────────────────────────────────────

database is local memory

create a Projects table:
  name, required
  status, default 'active'
  color, default 'blue'

create a WeeklyStats table:
  week, required
  opened (number), default 0
  closed (number), default 0

create an Issues table:
  title, required
  project, required
  assignee
  priority, default 'medium'
  status, default 'backlog'
  created_at_date, auto

# ── Backend ───────────────────────────────────────────────────────────────────

allow cross-origin requests
log every request

when user calls GET /api/projects:
  all_projects = get all Projects
  send back all_projects

when user calls POST /api/projects sending project_data:
  validate project_data:
    name is text, required, min 1, max 80
  new_project = save project_data as new Project
  send back new_project

when user calls GET /api/issues:
  all_issues = get all Issues
  send back all_issues

when user calls POST /api/issues sending issue_data:
  validate issue_data:
    title is text, required, min 1, max 200
    project is text, required
  new_issue = save issue_data as new Issue
  send back new_issue

when user calls DELETE /api/issues/:id:
  requires login
  delete the Issue with this id
  send back 'deleted'

when user calls GET /api/weekly-stats:
  all_weeks = get all WeeklyStats
  send back all_weeks

when user calls POST /api/seed:
  create i1:
    title is 'Fix auth token expiry on mobile'
    project is 'Backend'
    assignee is 'Sarah Chen'
    priority is 'high'
