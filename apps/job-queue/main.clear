build for javascript backend

# Job Queue -- Stress Test App #8
# Tests: background jobs, scheduling, retry, status tracking

# --- Data ---

create data shape Job:
  type is text, required
  payload is text
  status is text, default 'pending'
  attempts (number), default 0
  max_retries (number), default 3
  last_error is text
  created_at is timestamp, auto

# --- Config ---

log every request

# --- Endpoints ---

when user calls POST /api/jobs receiving job:
  this endpoint requires login
  validate job:
    type is text, required
  define new_job as: save job as Job
  send back new_job status 201

when user calls GET /api/jobs:
  this endpoint requires login
  define all_jobs as: look up all records in Job table
  send back all_jobs

when user calls GET /api/jobs/:id:
  this endpoint requires login
  define job as: look up records in Job table where id is incoming's id
  send back job

when user calls DELETE /api/jobs/:id:
  this endpoint requires login
  this endpoint requires role 'admin'
  remove from Jobs where id is incoming's id
  send back 'deleted'

# --- Workers ---

background 'process-pending-jobs':
  runs every 30 seconds

background 'cleanup-old-jobs':
  runs every 1 hour
