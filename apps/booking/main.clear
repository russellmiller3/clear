# ┌──────────┬──────────────────────────────┐
# │ Sidebar  │  Header          [New Booking]│
# │          ├──────────────────────────────┤
# │ Calendar │  ┌────────┐┌────────┐┌─────┐│
# │ Services │  │ Today  ││ Week   ││Rev. ││
# │ Clients  │  │   5    ││  23    ││$1.8k││
# │ Settings │  └────────┘└────────┘└─────┘│
# │          │  ┌──────────────────────────┐│
# │          │  │ Upcoming Bookings (table)││
# │          │  └──────────────────────────┘│
# └──────────┴──────────────────────────────┘
#
# DATAFLOW:
# ┌──────────┐  POST /api/bookings  ┌──────────┐  save   ┌────────┐
# │ Frontend │ ───────────────────> │ Backend  │ ──────> │  DB    │
# │  (forms) │ <─────────────────── │ (server) │ <────── │(memory)│
# └──────────┘  GET /api/bookings   └──────────┘  query  └────────┘

build for web and javascript backend

# Database
database is local memory

create a Services table:
  name, required
  duration (number), default 60
  price (number), default 0
  created_at_date, auto

create a Clients table:
  name, required
  email, required, unique
  phone
  created_at_date, auto

create a Bookings table:
  client_name, required
  service_name, required
  date, required
  time, required
  status, default 'pending'
  notes
  created_at_date, auto

# Backend

# Allow the frontend to talk to the backend
allow cross-origin requests

# Print every request to the console for debugging
log every request

# --- Seed data ---
when user calls POST /api/seed:
  create s1:
    name is 'Consultation'
    duration = 60
    price = 150
  save s1 as new Service
  create s2:
    name is 'Follow-up'
    duration = 30
    price = 75
  save s2 as new Service
  create b1:
    client_name is 'Sarah Johnson'
    service_name is 'Consultation'
    date is '2026-04-08'
    time is '10:00'
    status is 'confirmed'
  save b1 as new Booking
  create b2:
    client_name is 'Mike Peters'
    service_name is 'Follow-up'
    date is '2026-04-08'
    time is '14:00'
    status is 'pending'
  save b2 as new Booking
  send back 'seeded' with success message

# --- Services ---
when user calls GET /api/services:
  all_services = get all Services
  send back all_services

when user calls POST /api/services sending service_data:
  requires auth
  validate service_data:
    name is text, required
    duration is number
    price is number
  new_service = save service_data as new Service
  send back new_service with success message

when user calls DELETE /api/services/:id:
  requires auth
  delete the Service with this id
  send back 'deleted' with success message

# --- Clients ---
when user calls GET /api/clients:
  all_clients = get all Clients
  send back all_clients

when user calls POST /api/clients sending client_data:
  requires auth
  validate client_data:
    name is text, required
    email is text, required, matches email
    phone is text
  new_client = save client_data as new Client
  send back new_client with success message

# --- Bookings ---
when user calls GET /api/bookings:
  all_bookings = get all Bookings
  send back all_bookings

when user calls POST /api/bookings sending booking_data:
  requires auth
  validate booking_data:
    client_name is text, required
    service_name is text, required
    date is text, required
    time is text, required
    notes is text
  new_booking = save booking_data as new Booking
  send back new_booking with success message

when user calls DELETE /api/bookings/:id:
  requires auth
  delete the Booking with this id
  send back 'deleted' with success message

# Frontend
page 'BookIt' at '/':

  on page load:
    send nothing to '/api/seed'
    get bookings from '/api/bookings'
    get services from '/api/services'

  section 'Layout' with style app_layout:

    section 'Nav' with style app_sidebar:
      heading 'BookIt'
      text 'Calendar'
      text 'Services'
      text 'Clients'

    section 'Right' with style app_main:
      section 'Top' with style app_header:
        heading 'Upcoming Bookings'

      section 'Body' with style app_content:

        # --- New Booking ---
        section 'New Booking' with style app_card:
          subheading 'New Booking'
          'Client Name' is a text input saved as a client_name
          'Service' is a dropdown with ['Consultation', 'Follow-up']
          'Date' is a text input saved as a date
          'Time' is a text input saved as a time
          'Notes' is a text area saved as a notes
          button 'Book':
            send client_name and service and date and time and notes to '/api/bookings'
            get bookings from '/api/bookings'
            client_name is ''
            notes is ''

        # --- Bookings Table ---
        section 'Bookings' with style app_card:
          subheading 'All Bookings'
          display bookings as table showing client_name, service_name, date, time, status with delete

        # --- Services ---
        section 'Services' with style app_card:
          subheading 'Manage Services'
          'Service Name' is a text input saved as a service_name
          'Duration (min)' is a number input saved as a duration
          'Price' is a number input saved as a price
          button 'Add Service':
            send service_name and duration and price to '/api/services'
            get services from '/api/services'
            service_name is ''
          display services as table showing name, duration, price with delete
