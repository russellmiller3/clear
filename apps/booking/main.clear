# DATAFLOW:
# ┌──────────┐  POST /api/rooms      ┌──────────┐  save   ┌────────┐
# │ Frontend │  POST /api/bookings   │ Backend  │ ──────> │  DB    │
# │  (page)  │ ───────────────────> │ (server) │         │(memory)│
# │          │ <─────────────────── │          │ <────── │        │
# └──────────┘  GET /api/rooms       └──────────┘  query  └────────┘
#      │         GET /api/bookings        │
#      │  page load --> GET --> display   │  DELETE requires login
#      │  form submit --> POST --> refresh│  GET /api/rooms/:id/bookings

build for web and javascript backend

# Database
database is local memory

create a Rooms table:
  name, required
  capacity (number)
  description
  bookings has many Bookings

create a Bookings table:
  guest_name, required
  date, required
  time, required
  notes
  created_at_date, auto
  room belongs to Rooms

# Backend
allow cross-origin requests
log every request

when user calls POST /api/seed:
  create r1:
    name is 'Conference A'
    capacity = 10
    description is 'Large meeting room with projector'
  save r1 as new Room
  create r2:
    name is 'Conference B'
    capacity = 6
    description is 'Small huddle room'
  save r2 as new Room
  create r3:
    name is 'Lounge'
    capacity = 20
    description is 'Open lounge area'
  save r3 as new Room
  create b1:
    guest_name is 'Alice Smith'
    date is '2026-04-14'
    time is '09:00'
    room_id = 1
  save b1 as new Booking
  create b2:
    guest_name is 'Bob Jones'
    date is '2026-04-14'
    time is '14:00'
    room_id = 2
  save b2 as new Booking
  create b3:
    guest_name is 'Carol Lee'
    date is '2026-04-15'
    time is '10:00'
    room_id = 1
  save b3 as new Booking
  create b4:
    guest_name is 'Dan Park'
    date is '2026-04-15'
    time is '16:00'
    room_id = 3
  save b4 as new Booking
  send back 'seeded' with success message

when user calls GET /api/rooms:
  all_rooms = get all Rooms
  send back all_rooms

when user calls POST /api/rooms sending room_data:
  validate room_data:
    name is text, required
    capacity is number
    description is text
  new_room = save room_data as new Room
  send back new_room with success message

when user calls DELETE /api/rooms/:id:
  requires login
  delete the Room with this id
  send back 'deleted' with success message

when user calls GET /api/bookings:
  all_bookings = get all Bookings
  send back all_bookings

when user calls POST /api/bookings sending booking_data:
  validate booking_data:
    guest_name is text, required
    date is text, required
    time is text, required
    notes is text
  new_booking = save booking_data as new Booking
  send back new_booking with success message

when user calls DELETE /api/bookings/:id:
  requires login
  delete the Booking with this id
  send back 'deleted' with success message

when user calls GET /api/bookings/search sending query:
  results = search Bookings for query
  send back results

# Frontend
page 'Room Booking' at '/':

  on page load:
    send nothing to '/api/seed'
    get rooms from '/api/rooms'
    get bookings from '/api/bookings'

  section 'Rooms' with style page_section:
    heading 'Rooms'
    display rooms as cards showing name, capacity, description

  section 'Book a Room' with style page_section:
    heading 'Book a Room'
    'Guest Name' is a text input saved as a guest_name
    'Date' is a text input saved as a date
    'Time' is a text input saved as a time
    'Room' is a dropdown with ['Conference A', 'Conference B', 'Lounge']
    'Notes' is a text area saved as a notes
    button 'Book Now':
      send guest_name and date and time and room and notes to '/api/bookings'
      get bookings from '/api/bookings'
      guest_name is ''
      notes is ''

  section 'Bookings' with style page_section:
    heading 'All Bookings'
    display bookings as table showing guest_name, date, time, room, notes with delete
