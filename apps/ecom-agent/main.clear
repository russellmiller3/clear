# Frontend

page 'Support Chat' at '/':
  section 'Layout' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      heading 'TechGear'
      subheading 'Support Center'
      divider
      link 'Chat' goes to '/'
      link 'Orders' goes to '/orders'
      link 'Dashboard' goes to '/admin'

    section 'Main' with style app_main:
      section 'Header' with style app_header:
        heading 'Customer Support'
        subheading 'Ask about orders, returns, or products'

      section 'Content' with style app_content:
        on page load get messages from '/api/messages'

        display messages as chat showing role, content

        'Type your message...' is a text input saved as message

        button 'Send':
          send message to '/api/chat'
          get messages from '/api/messages'
          message is ''

page 'Orders' at '/orders':
  section 'Layout' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      heading 'TechGear'
      subheading 'Support Center'
      divider
      link 'Chat' goes to '/'
      link 'Orders' goes to '/orders'
      link 'Dashboard' goes to '/admin'

    section 'Main' with style app_main:
      section 'Header' with style app_header:
        heading 'Orders'

      section 'Content' with style app_content:
        on page load get orders from '/api/orders'
        display orders as table showing customer_name, items, total, status, tracking_number

page 'Admin Dashboard' at '/admin':
  section 'Layout' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      heading 'TechGear'
      subheading 'Support Center'
      divider
      link 'Chat' goes to '/'
      link 'Orders' goes to '/orders'
      link 'Dashboard' goes to '/admin'

    section 'Main' with style app_main:
      section 'Header' with style app_header:
        heading 'Operations Dashboard'

      section 'Content' with style app_content:
        on page load:
          get stats from '/api/stats'
          get low_items from '/api/inventory/low'
          get products from '/api/products'

        section 'Key Metrics' with style split:
          section 'Card' with style app_card:
            heading 'Total Orders'
            display stats's total_orders as count
          section 'Card' with style app_card:
            heading 'Revenue'
            display stats's total_revenue as dollars
          section 'Card' with style app_card:
            heading 'Returns'
            display stats's total_returns as count
          section 'Card' with style app_card:
            heading 'Low Stock'
            display stats's low_stock_count as count

        section 'Inventory Alerts':
          if length of low_items is greater than 0:
            for each item in low_items list:
              section 'Card' with style app_card:
                text '{item's name} ({item's sku})'
                text '{item's stock} remaining — reorder at {item's reorder_threshold}'
                badge 'Low Stock' with style 'warning'
          otherwise:
            text 'All stock levels healthy'

        section 'Product Catalog':
          display products as cards showing name, category, price, stock
