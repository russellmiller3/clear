# Tests

test:
  mock claude responding:
    text is 'Your order #1 has been delivered. Tracking: TRK-20260401-001'
  result = call 'Customer Support' with 'Where is my order 1?'
  expect result contains 'order'

test:
  mock claude responding:
    text is 'I can help you with that return. Processing now.'
  result = call 'Customer Support' with 'I want to return my purchase'
  expect result contains 'return'

test:
  create low_item:
    name is 'Test Widget'
    sku is 'TW-001'
    price = 9.99
    stock = 3
    reorder_threshold = 10
  save low_item as new Product
  result = get_low_stock_items()
  expect length of result is greater than 0

