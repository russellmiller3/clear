/*
Ecom Agent — AI-powered e-commerce customer support

DEMO: Customer support chat with intent routing, order lookup,
return processing, stock checking, inventory alerts, and admin dashboard.

DATAFLOW:
                              classify
  Customer ──► Chat ──► Intent Router ──┬──► Order Lookup ──► DB
                                        ├──► Return Processing ──► DB + Email
                                        ├──► Stock Check ──► DB
                                        └──► General Support

  Background ──► Inventory Monitor (every 6 hours) ──► Low Stock Alerts
             ──► Daily Report (every day at 9 AM) ──► Email Summary
*/

build for web and javascript backend
database is local memory
allow signup and login
log every request

# Database

create a Products table:
  name, required
  sku, required, unique
  category, default 'general'
  price (number), required
  stock (number), default 0
  reorder_threshold (number), default 10
  image_url

create an Orders table:
  customer_name, required
  customer_email, required
  items, required
  total (number), required
  status, default 'pending'
  tracking_number
  created_at (timestamp), auto

create a Returns table:
  order_id (number), required
  reason, required
  status, default 'requested'
  refund_amount (number)
  created_at (timestamp), auto

create a Messages table:
  role, required
  content, required
  intent
  created_at (timestamp), auto

create a Conversations table:
  user_id
  messages
  created_at (timestamp), auto

# Tools

define function lookup_order(order_id):
  order = look up Order where id is order_id
  return order

define function lookup_orders_by_email(email):
  orders = look up all Orders where customer_email is email
  return orders

define function check_stock(product_name):
  results = search Products for product_name
  return results

define function process_return(target_order_id, return_reason):
  order = look up Order where id is target_order_id
  guard order is not missing or 'Order not found'
  guard order's status is 'delivered' or 'Only delivered orders can be returned'
  create return_record:
    order_id is target_order_id
    reason is return_reason
    refund_amount is order's total
    status is 'approved'
  save return_record as new Return
  set order's status to 'returned'
  save order to Orders
  return return_record

define function get_low_stock_items():
  products = get all Products
  low_stock is an empty list
  for each product in products list:
    if product's stock is less than product's reorder_threshold:
      add product to low_stock
  return low_stock

# Skills

skill 'Order Management':
  has tools: lookup_order, lookup_orders_by_email
  instructions:
    Always look up the order before taking action.
    Include the order status and tracking number in your response.
    Be empathetic about delays.

skill 'Returns':
  has tool: process_return
  instructions:
    Only process returns for delivered orders.
    Always explain the refund timeline (5-7 business days).
    If the order is not eligible, explain why.

skill 'Inventory':
  has tools: check_stock, get_low_stock_items
  instructions:
    Report stock levels precisely.
    Suggest alternatives if an item is out of stock.

# Agent

agent 'Customer Support' receives message:
  uses skills: 'Order Management', 'Returns', 'Inventory'
  knows about: Products, Orders
  remember conversation context
  track agent decisions
  block arguments matching 'drop|truncate|delete.*all'
  must not:
    modify Products table

  intent = classify message as 'order status', 'return or refund', 'product availability'

  match intent:
    when 'order status':
      response = ask claude 'Help this customer check their order. Look it up by ID or email and give a clear status update with tracking info if available.' with message
    when 'return or refund':
      response = ask claude 'Help with this return request. Process it if the order is delivered. Explain the refund timeline.' with message
    when 'product availability':
      response = ask claude 'Check if this product is in stock. Give the exact count. Suggest alternatives if out of stock.' with message
    otherwise:
      response = ask claude 'You are a friendly e-commerce support agent for TechGear Store. Help the customer with their question about our electronics products.' with message

  send back response

# Scheduled Tasks

background 'Inventory Monitor':
  runs every 6 hours
  low_items = get_low_stock_items()
  if length of low_items is greater than 0:
    for each item in low_items list:
      show 'LOW STOCK ALERT: {item's name} ({item's sku}) — {item's stock} remaining'

background 'Daily Report':
  runs every 1 day at '9:00 AM'
  orders = get all Orders
  returns = get all Returns
  low_stock = get_low_stock_items()
  total_revenue = sum of total in orders
  show 'DAILY REPORT: {length of orders} orders, ${total_revenue} revenue, {length of returns} returns, {length of low_stock} low stock items'

# Endpoints

when user sends data to /api/chat:
  requires login
  create user_msg:
    role is 'user'
    content is data's message
  save user_msg as new Message
  result = call 'Customer Support' with data's message
  create bot_msg:
    role is 'assistant'
    content is result
  save bot_msg as new Message
  send back result

when user requests data from /api/messages:
  messages = get all Messages
  send back messages

when user requests data from /api/orders:
  orders = get all Orders
  send back orders

when user requests data from /api/products:
  products = get all Products
  send back products

when user requests data from /api/inventory/low:
  low_items = get_low_stock_items()
  send back low_items

when user requests data from /api/stats:
  orders = get all Orders
  all_returns = get all Returns
  products = get all Products
  low_stock = get_low_stock_items()
  total_revenue = sum of total in orders
  create stats:
    total_orders is length of orders
    total_revenue is total_revenue
    total_returns is length of all_returns
    total_products is length of products
    low_stock_count is length of low_stock
  send back stats

