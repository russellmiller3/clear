build for javascript backend

database is local memory

create a Leads table:
  company, required
  email, required
  score (number), default 0
  analysis
  scored_at_date, auto

agent 'Lead Scorer' receives lead:
  check lead's company is not missing, otherwise error 'Company is required'
  set lead's score to ask ai 'Give a best-guess enterprise-sales-potential score from 1 to 10 for this company based on its name alone. Reply with ONLY a single digit between 1 and 9. Never refuse. Never add explanation. If the name is unfamiliar, pick a middle value like 5.' with lead's company
  set lead's analysis to ask ai 'Write one sentence describing what this company likely does, based on the name. Never refuse, never ask for more information. Keep it under 30 words.' with lead's company
  send back lead

when user calls POST /api/score sending lead_data:
  requires login
  validate lead_data:
    company is text, required
    email is text, required
  set scored to call 'Lead Scorer' with lead_data
  set saved to save scored as new Lead
  send back saved with success message

when user calls GET /api/leads:
  all_leads = get all Leads
  send back all_leads

when user calls GET /api/health:
  send back 'ok'
