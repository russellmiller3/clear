# CRM SPA — Backend
# All database tables, API endpoints, seed data, and SSE streaming

# Database Tables
create a Contacts table:
  name, required
  email, required, unique
  company
  phone
  status, default 'lead'
  source, default 'direct'
  notes
  created_at_date, auto

create a Deals table:
  contact_id, required
  title, required
  value (number), default 0
  stage, default 'prospect'
  probability (number), default 10
  expected_close
  created_at_date, auto

create a Activities table:
  contact_id
  deal_id
  action, required
  detail
  performed_by, default 'system'
  created_at_date, auto

create a Tags table:
  name, required, unique
  color, default 'blue'

# Allow the frontend to talk to the backend
allow cross-origin requests

# Print every request to the console for debugging
log every request

# --- Seed Data ---
when user calls POST /api/seed:
  create c1:
    name is 'Alice Chen'
    email is 'alice@acme.co'
    company is 'Acme Corporation'
    phone is '555-0101'
    status is 'customer'
    source is 'referral'
