  save t2 as new Tag
  send back 'seeded' with success message

# --- Contacts CRUD ---
when user calls GET /api/contacts:
  all_contacts = get all Contacts
  send back all_contacts

when user calls POST /api/contacts sending contact:
  requires login
  validate contact:
    name is text, required, min 1, max 100
    email is text, required, matches email
    company is text
    phone is text
    status is text
    source is text
    notes is text
  new_contact = save contact as new Contact
  send back new_contact with success message

when user calls PUT /api/contacts/:id sending contact:
  requires login
  validate contact:
    name is text
    email is text
    company is text
    phone is text
    status is text
    notes is text
  save contact to Contacts
  send back 'updated' with success message

when user calls DELETE /api/contacts/:id:
  requires login
  delete the Contact with this id
  send back 'deleted' with success message

# --- Deals CRUD ---
when user calls GET /api/deals:
  all_deals = get all Deals
  send back all_deals

when user calls POST /api/deals sending deal:
  requires login
  validate deal:
    contact_id is text, required
    title is text, required, min 1, max 200
    value is number
    stage is text
    probability is number
    expected_close is text
  new_deal = save deal as new Deal
  send back new_deal with success message

when user calls PUT /api/deals/:id sending deal:
  requires login
  validate deal:
    title is text
    value is number
    stage is text
    probability is number
    expected_close is text
  save deal to Deals
  send back 'updated' with success message

when user calls DELETE /api/deals/:id:
  requires login
  delete the Deal with this id
  send back 'deleted' with success message

# --- Activities ---
when user calls GET /api/activities:
  all_activities = get all Activities
  send back all_activities

when user calls POST /api/activities sending activity:
  requires login
  validate activity:
    contact_id is text
    deal_id is text
    action is text, required
    detail is text
    performed_by is text
  new_activity = save activity as new Activity
  send back new_activity with success message

# --- Activity Stream (SSE) ---
when user calls GET /api/activity/stream:
  stream:
    send back 'heartbeat'

# --- Tags ---
when user calls GET /api/tags:
  all_tags = get all Tags
  send back all_tags

when user calls POST /api/tags sending tag:
  requires login
  validate tag:
    name is text, required
    color is text
  new_tag = save tag as new Tag
  send back new_tag with success message

# --- Health ---
when user calls GET /api/health:
  send back 'ok'
