/*
Expense Tracker — personal spending with categories, charts, and aggregates

  ┌──────────┐   GET/POST/DELETE   ┌──────────┐   CRUD    ┌────────────┐
  │ Browser  │ ─────────────────►  │  Server  │ ────────► │ Categories │
  │ (page)   │ ◄─────────────────  │ (Express)│           └────────────┘
  └──────────┘    JSON + HTML      │          │   CRUD    ┌────────────┐
       │                           │          │ ────────► │  Expenses  │
       │ pie chart ◄───────────    └──────────┘           └────────────┘
       │ total_spent ◄─────────         │                      │
       │                           sum(amount)            belongs to
       │                           Search (keyword)       Categories
       └── computed: total, chart    Auth (JWT)
*/

# JUMP TO: Database | Backend | Middleware | Endpoints | Seed Data | Frontend

build for web and javascript backend

# Database

database is local memory

create a Categories table:
  name
  expenses has many Expenses

create a Expenses table:
  description, required
  amount (number), required
  created_at, auto
  category belongs to Categories

# Backend
# Middleware

allow server to accept requests from frontend
allow signup and login
log every request

# Endpoints

when user requests data from /api/expenses:
  all_expenses = get all Expenses
  send back all_expenses

when user sends expense_data to /api/expenses:
  requires login
  validate expense_data:
    description is text, required, min 1, max 200
    amount is number, required
  new_expense = save expense_data as new Expense
  send back new_expense with success message

when user deletes expense at /api/expenses/:id:
  requires login
  delete the Expense with this id
  send back 'deleted' with success message

when user requests data from /api/categories:
  all_categories = get all Categories
  send back all_categories

when user requests data from /api/search:
  results = search Expenses for incoming's q
  send back results

when user requests data from /api/expenses/total:
  all_expenses = get all Expenses
  total = sum of amount in all_expenses
  send back total

# Seed Data

when user sends data to /api/seed:
  create c1:
    name is 'Food'
  save c1 as new Category
  create c2:
    name is 'Transport'
  save c2 as new Category
  create c3:
    name is 'Entertainment'
  save c3 as new Category
  create c4:
    name is 'Bills'
  save c4 as new Category
  create e1:
    description is 'Groceries'
    amount = 45.50
    category = c1's id
  save e1 as new Expense
  create e2:
    description is 'Bus pass'
    amount = 30
    category = c2's id
  save e2 as new Expense
  create e3:
    description is 'Movie tickets'
    amount = 24
    category = c3's id
  save e3 as new Expense
  create e4:
    description is 'Electric bill'
    amount = 89.99
    category = c4's id
  save e4 as new Expense
  create e5:
    description is 'Coffee and lunch'
    amount = 18.75
    category = c1's id
  save e5 as new Expense
  create e6:
    description is 'Internet bill'
    amount = 59.99
    category = c4's id
  save e6 as new Expense
  send back 'seeded' with success message

# Frontend

page 'Expense Tracker':
  on page load get expenses from '/api/expenses'

  heading 'Expense Tracker'
  subheading 'Track your spending'

  section 'Add Expense' with style card:
    'Description' is a text input saved as a description
    'Amount' is a number input saved as a amount
    'Category' is a dropdown with ['Food', 'Transport', 'Entertainment', 'Bills', 'Other'] saved as a category
    button 'Add Expense':
      send description, amount and category as a new expense to '/api/expenses'
      get expenses from '/api/expenses'
      description is ''
      amount is 0

  section 'Search':
    'Search expenses' is a text input saved as a search_query
    button 'Search':
      get expenses from '/api/search'

  section 'Summary':
    define total_spent as: sum of amount in expenses
    display total_spent as dollars called 'Total Spent'

  section 'All Expenses':
    display expenses as table showing description, amount, category with delete

  section 'Spending by Category':
    pie chart 'Spending by Category' showing expenses by category

# Tests

test 'list expenses returns 200':
  call GET /api/expenses
  expect response status is 200

test 'create expense with valid data':
  call POST /api/expenses with description is 'Test expense' and amount is 42
  expect response status is 201
  expect response body has id

test 'create expense rejects missing amount':
  call POST /api/expenses with description is 'No amount'
  expect response status is 400

test 'delete expense requires auth':
  call DELETE /api/expenses/1
  expect response status is 401

test 'expense total returns aggregate':
  call GET /api/expenses/total
  expect response status is 200
