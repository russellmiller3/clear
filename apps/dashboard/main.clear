# LAYOUT:
# ┌─────────────┬──────────────────────────┐
# │ Sidebar     │ Header      [Add Model]  │
# │             ├──────────────────────────┤
# │ Search      │ ┌──────────┐ ┌─────────┐ │
# │ Models list │ │ Accuracy │ │ Models  │ │
# │             │ └──────────┘ └─────────┘ │
# │             │ ┌──────────────────────┐ │
# │             │ │ Accuracy Chart       │ │
# │             │ ├──────────────────────┤ │
# │             │ │ Models Table (CRUD)  │ │
# │             │ └──────────────────────┘ │
# └─────────────┴──────────────────────────┘

build for web and javascript backend
database is local memory

create a Models table:
  name, required
  accuracy (number), default 0
  status, default 'pending'
  created_at_date, auto

# Backend

allow cross-origin requests

when user calls GET /api/models:
  all_models = get all Models
  send back all_models

when user calls POST /api/models sending model_data:
  validate model_data:
    name is text, required, min 1, max 100
  new_model = save model_data as new Model
  send back new_model with success message

when user calls PUT /api/models/:id sending update_data:
  requires auth
  save update_data to Models
  send back update_data with success message

when user calls DELETE /api/models/:id:
  requires auth
  delete the Model with this id
  send back 'deleted' with success message

when user calls POST /api/seed:
  create m1:
    name is 'Revenue Predictor'
    accuracy = 92
    status is 'complete'
  save m1 as new Model
  create m2:
    name is 'Churn Classifier'
    accuracy = 87
    status is 'complete'
  save m2 as new Model
  create m3:
    name is 'Lead Scorer'
    accuracy = 78
    status is 'training'
  save m3 as new Model
  create m4:
    name is 'Demand Forecast'
    accuracy = 94
    status is 'complete'
  save m4 as new Model
  send back 'seeded' with success message

# Frontend

page 'ML Dashboard' at '/':
  on page load:
    send nothing to '/api/seed'
    get models from '/api/models'

  section 'Layout' with style app_layout:
    section 'Nav' with style app_sidebar:
      heading 'ML Dashboard'
      divider
      text 'Models'
      text 'Experiments'
      text 'Datasets'
      text 'Settings'
      divider
      'Filter models' is a text input saved as a search

    section 'Right' with style app_main:
      section 'Top' with style app_header:
        heading 'Models'
        'Model Name' is a text input saved as a model_name

      section 'Body' with style app_content:
        section 'Metrics' as two column layout:
          section 'Accuracy' with style metric_card:
            small text 'Avg Accuracy'
            heading '87.8%'
            text 'Across 4 models'
          section 'Count' with style metric_card:
            small text 'Total Models'
            heading '4'
            text '3 complete, 1 training'

        button 'Add Model':
          send model_name as a new model to '/api/models'
          get models from '/api/models'
          model_name is ''

        chart 'Model Accuracy' as bar showing models

        display models as table showing name, accuracy, status with delete and edit
