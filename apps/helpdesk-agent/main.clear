# Helpdesk Agent -- AI support bot with tools, RAG, memory, and guardrails
#
# DATAFLOW:
# POST /api/ask
# +----------+  question   +------------------+  ask ai  +-------+
# |  Client  | ---------> |  Helpdesk Agent  | -------> | Claude |
# +----------+            |  [tools, RAG,    | <------- |        |
#                         |   memory, guard] |          +-------+
#                         +------------------+

build for javascript backend
database is local memory
allow signup and login

# === DATABASE ===

create a Products table:
  name, required
  description
  price (number)

create a Tickets table:
  subject, required
  status, default 'open'
  customer_email
  created_at (timestamp), auto

# === CRUD ===

when user calls POST /api/products sending data:
  saved = save data as new Product
  send back saved with success message

when user calls GET /api/products:
  products = get all Products
  send back products

when user calls PUT /api/products:id sending data:
  requires login
  save data to Products
  send back 'updated' with success message

when user calls DELETE /api/products:id:
  requires login
  delete the Product with this id
  send back 'deleted' with success message

when user calls POST /api/tickets sending data:
  saved = save data as new Ticket
  send back saved with success message

when user calls GET /api/tickets:
  tickets = get all Tickets
  send back tickets

when user calls PUT /api/tickets:id sending data:
  requires login
  save data to Tickets
  send back 'updated' with success message

when user calls DELETE /api/tickets:id:
  requires login
  delete the Ticket with this id
  send back 'deleted' with success message

# === SEARCH ===

when user calls GET /api/products/search sending query:
  results = search Products for query
  send back results

# === AGENT TOOLS ===

define function lookup_product(query):
  results = search Products for query
  return results

define function create_ticket(subject, customer_email):
  create new_ticket:
    subject is subject
    customer_email is customer_email
  saved = save new_ticket as new Ticket
  return saved

# === AGENT ===

agent 'Helpdesk' receives question:
  can use: lookup_product, create_ticket
  knows about: Products
  remember conversation context
  block arguments matching 'delete|drop|truncate'
  response = ask claude 'You are a helpful customer support agent. Help the customer with their question about our products. You can look up products and create support tickets.' with question
  send back response

when user calls POST /api/ask sending data:
  result = call 'Helpdesk' with data's question
  send back result

# === SEED ===

when user calls POST /api/seed:
  create p1:
    name is 'Wireless Keyboard'
    description is 'Ergonomic bluetooth keyboard with backlit keys'
    price = 49.99
  save p1 as new Product
  create p2:
    name is 'USB-C Hub'
    description is '7-port hub with HDMI, ethernet, and card reader'
    price = 34.99
  save p2 as new Product
  create p3:
    name is 'Monitor Stand'
    description is 'Adjustable aluminum stand with cable management'
    price = 79.99
  save p3 as new Product
  create p4:
    name is 'Webcam HD'
    description is '1080p webcam with noise-canceling microphone'
    price = 59.99
  save p4 as new Product
  create p5:
    name is 'Laptop Sleeve'
    description is 'Padded neoprene sleeve fits up to 15 inch laptops'
    price = 24.99
  save p5 as new Product
  send back 'Seeded 5 products' with success message

# === FRONTEND ===

page 'Helpdesk':
  heading 'Product Support Chat'

  'Ask about our products...' is a text input saved as question

  button 'Ask':
    send question to '/api/ask'

  display response called 'Answer'

  heading 'Our Products'

  on page load get products from '/api/products'

  display products as cards showing name, description, price
