build for javascript backend

database is local memory

create a Candidates table:
  name is text, required
  role is text, required
  experience is text, required
  skills is text
  screening_pass
  score (number), default 0
  summary
  applied_at_date, auto

agent 'Screener' receiving candidate:
  check candidate's name is not missing, otherwise error 'Name is required'
  check candidate's role is not missing, otherwise error 'Role is required'
  set candidate's screening_pass to ask ai 'Does this candidate meet minimum qualifications? Reply YES or NO only.' with candidate's experience
  send back candidate

agent 'Scorer' receiving candidate:
  set candidate's score to ask ai 'Rate this candidate 1-10 based on skills fit. Reply with just the number.' with candidate's skills
  send back candidate

agent 'Summarizer' receiving candidate:
  set candidate's summary to ask ai 'Write a 2-sentence hiring recommendation.' with candidate's experience
  send back candidate

when user calls POST /api/apply sending candidate_data:
  validate candidate_data:
    name is text, required
    role is text, required
    experience is text, required
  set screened to call 'Screener' with candidate_data
  set scored to call 'Scorer' with screened
  set summarized to call 'Summarizer' with scored
  set saved to save summarized as new Candidate
  send back saved with success message

when user calls GET /api/candidates:
  all_candidates = get all Candidates
  send back all_candidates

when user calls GET /api/health:
  send back 'ok'
