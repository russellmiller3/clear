# Frontend

# Shared sidebar — referenced from every page so nav persists across routes.
# Counts are static placeholders here (decorative); live counts only matter
# on the Deal Desk root page where they're loaded fresh from /api/deals/pending.
define component DealDeskSidebar:
  heading 'Deal Desk'

  nav section 'Approvals':
    nav item 'Pending' to '/' with icon 'inbox'
    nav item 'Approved today' to '/approved' with icon 'check-circle-2'
    nav item 'Rejected' to '/rejected' with icon 'x-circle'
    nav item 'Awaiting customer' to '/awaiting' with icon 'clock'

  nav section 'Pipeline':
    nav item 'All deals' to '/all' with icon 'layers'
    nav item 'Reps' to '/reps' with icon 'users'
    nav item 'Accounts' to '/accounts' with icon 'building-2'
    nav item 'Reports' to '/reports' with icon 'bar-chart-3'

  nav section 'Workspace':
    nav item 'Approval rules' to '/rules' with icon 'git-branch'
    nav item 'Integrations' to '/integrations' with icon 'puzzle'
    nav item 'Settings' to '/settings' with icon 'settings'

  section 'Quota' with style app_card:
    small text 'Quota: 78%'
    text '$2.3M of $3M'

page 'Deal Desk' at '/':
  on page load:
    send nothing to '/api/seed'
    get pending from '/api/deals/pending'

  pending_count = count of pending
  approved_today_count = 12
  rejected_count = 3
  awaiting_count = 7
  total_deals_count = 148
  rep_count = 22
  average_discount is '22.4%'
  value_at_stake is '$348K'
  approvals_week_count = 38

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      heading 'Deal Desk'

      nav section 'Approvals':
        nav item 'Pending' to '/' with count pending_count with icon 'inbox'
        nav item 'Approved today' to '/approved' with count approved_today_count with icon 'check-circle-2'
        nav item 'Rejected' to '/rejected' with count rejected_count with icon 'x-circle'
        nav item 'Awaiting customer' to '/awaiting' with count awaiting_count with icon 'clock'

      nav section 'Pipeline':
        nav item 'All deals' to '/all' with count total_deals_count with icon 'layers'
        nav item 'Reps' to '/reps' with count rep_count with icon 'users'
        nav item 'Accounts' to '/accounts' with icon 'building-2'
        nav item 'Reports' to '/reports' with icon 'bar-chart-3'

      nav section 'Workspace':
        nav item 'Approval rules' to '/rules' with icon 'git-branch'
        nav item 'Integrations' to '/integrations' with icon 'puzzle'
        nav item 'Settings' to '/settings' with icon 'settings'

      section 'Quota' with style app_card:
        small text 'Quota: 78%'
        text '$2.3M of $3M'

    section 'Main' with style app_main:
      section 'Header' with style app_header:
        heading 'Clear'
        text 'Workspace / Deal Desk / Pending Queue'

      section 'Content' with style app_content:
        page header 'Pending CRO approval':
          subtitle '{pending_count} deals waiting on you. Oldest submitted 2 hours ago.'
          actions:
            button 'Refresh'
            button 'Export'
            button 'New deal'

        tab strip:
          active tab is 'Pending'
          tab 'Pending' to '/'
          tab 'My approvals' to '/approved'
          tab 'All' to '/all'

        stat strip:
          stat card 'Pending count':
            value pending_count
            delta 'same as yesterday'
            icon 'inbox'
          stat card 'Avg discount':
            value average_discount
            delta '+1.8 pts vs last week'
            icon 'percent'
          stat card 'Value at stake':
            value value_at_stake
            delta '+12% vs last week'
            icon 'dollar-sign'
          stat card 'Approvals - 7-day':
            value approvals_week_count
            delta '+6 vs prior 7 days'
            sparkline [4, 6, 5, 8, 7, 10, 9]

        section 'Queue Workbench' side by side, fills remaining space:
          section 'Pending Queue' with style app_table, fills remaining space:
            display pending as table showing customer, account_segment, rep_name, list_price, discount_percent, status, submitted_label with actions:
              'Review' is secondary
              'Approve' is primary

          detail panel for selected_deal:
            heading 'Deal details'
            text selected_deal's customer
            text selected_deal's summary
            display selected_deal's list_price as dollars called 'List price'
            display selected_deal's discount_percent as percent called 'Discount'
            display selected_deal's risk_score as number called 'Risk score'
            text selected_deal's recommendation
            text selected_deal's approval_rule
            text selected_deal's term
            text selected_deal's health_signal
            text selected_deal's precedent_note
            actions:
              button 'Reject'
              button 'Counter'
              button 'Approve'

        section 'Footer' as row:
          small text '{pending_count} pending'
          small text 'synced 12 sec ago'
          small text 'Clear Cloud'

page 'Approved today' at '/approved':
  on page load:
    get approved_deals from '/api/deals/approved'

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      show DealDeskSidebar()
    section 'Main' with style app_main:
      section 'Content' with style app_content:
        page header 'Approved today':
          subtitle 'Approved requests cleared today and ready for audit.'

        section 'Approved Deals' with style app_table:
          display approved_deals as table showing customer, account_segment, rep_name, list_price, discount_percent, status, submitted_label

page 'Rejected' at '/rejected':
  on page load:
    get rejected_deals from '/api/deals/rejected'

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      show DealDeskSidebar()
    section 'Main' with style app_main:
      section 'Content' with style app_content:
        page header 'Rejected deals':
          subtitle 'Requests rejected after CRO review.'

        section 'Rejected Deals' with style app_table:
          display rejected_deals as table showing customer, account_segment, rep_name, list_price, discount_percent, status, submitted_label

page 'Awaiting customer' at '/awaiting':
  on page load:
    get awaiting_deals from '/api/deals/awaiting'

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      show DealDeskSidebar()
    section 'Main' with style app_main:
      section 'Content' with style app_content:
        page header 'Awaiting customer':
          subtitle 'Counters, signatures, and procurement follow-ups needing customer action.'

        section 'Customer Follow-up' with style app_table:
          display awaiting_deals as table showing customer, account_segment, rep_name, list_price, discount_percent, status, submitted_label

page 'All deals' at '/all':
  on page load:
    get all_deals from '/api/deals/all'

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      show DealDeskSidebar()
    section 'Main' with style app_main:
      section 'Content' with style app_content:
        page header 'All deals':
          subtitle 'Total deal-desk requests across every status.'

        chart 'Approval mix' as pie showing all_deals by status
        chart 'Segment pressure' as bar showing all_deals by account_segment

        section 'Deal Audit Trail' with style app_table:
          display all_deals as table showing customer, account_segment, rep_name, deal_type, list_price, discount_percent, status, submitted_label

page 'Reps' at '/reps':
  on page load:
    get reps from '/api/reps'

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      show DealDeskSidebar()
    section 'Main' with style app_main:
      section 'Content' with style app_content:
        page header 'Reps':
          subtitle 'Reps with active or recent discount requests.'

        section 'Rep Performance' with style app_table:
          display reps as table showing rep_name, team, open_requests, approved_today, average_discount, value_at_stake, risk_flag

page 'Accounts' at '/accounts':
  on page load:
    get accounts from '/api/accounts'

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      show DealDeskSidebar()
    section 'Main' with style app_main:
      section 'Content' with style app_content:
        page header 'Accounts':
          subtitle 'Accounts with recent deal-desk context.'

        section 'Account Context' with style app_table:
          display accounts as table showing customer, account_segment, owner, active_requests, total_value, last_decision, health_signal

page 'Reports' at '/reports':
  on page load:
    get all_deals from '/api/deals/all'

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      show DealDeskSidebar()
    section 'Main' with style app_main:
      section 'Content' with style app_content:
        page header 'Reports':
          subtitle 'Approval velocity, discount pressure, and value-at-stake reporting.'

        chart 'Status mix' as pie showing all_deals by status
        chart 'Segment pressure' as bar showing all_deals by account_segment
        chart 'Deal types' as pie showing all_deals by deal_type

        section 'Reports Detail' with style app_table:
          display all_deals as table showing customer, status, list_price, discount_percent, submitted_label

page 'Approval rules' at '/rules':
  on page load:
    get approval_rules from '/api/approval-rules'

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      show DealDeskSidebar()
    section 'Main' with style app_main:
      section 'Content' with style app_content:
        page header 'Approval rules':
          subtitle 'Policies that explain why deals route to CRO review.'

        section 'Rules' with style app_table:
          display approval_rules as table showing rule_name, threshold, owner, status, last_updated

page 'Integrations' at '/integrations':
  on page load:
    get integrations from '/api/integrations'

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      show DealDeskSidebar()
    section 'Main' with style app_main:
      section 'Content' with style app_content:
        page header 'Integrations':
          subtitle 'Sync health for the systems that keep deal context trustworthy.'

        section 'Integration Health' with style app_table:
          display integrations as table showing system_name, sync_status, last_sync, records_synced, owner

page 'Settings' at '/settings':
  approval_threshold = 20
  auto_approve_limit = 10
  crm_sync_enabled = true
  email_alerts_enabled = true

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      show DealDeskSidebar()
    section 'Main' with style app_main:
      section 'Content' with style app_content:
        page header 'Settings':
          subtitle 'Workspace controls for approval policy, notifications, and sync defaults.'

        section 'Approval Controls' with style form:
          'Approval threshold (%)' as number input saves to approval_threshold
          'Auto-approve limit (%)' as number input saves to auto_approve_limit
          'CRM sync enabled' as checkbox saves to crm_sync_enabled
          'Email alerts enabled' as checkbox saves to email_alerts_enabled
          button 'Save settings':
            show 'Settings saved'

page 'New discount request' at '/new':
  section 'Header' centered, padded:
    heading 'New discount request'
    text 'Submit a discount request. Over 20 percent goes to the CRO queue.'

  section 'New discount request' with style form:
    'Your name' as text input saves to rep_name
    'Customer' as text input saves to customer
    'List price ($)' as number input saves to list_price
    'Discount %' as number input saves to discount_percent
    button 'Submit for approval':
      send rep_name, customer, list_price, and discount_percent to '/api/deals'
      rep_name is ''
      customer is ''
      list_price = 0
      discount_percent = 0

  link 'Back to queue' goes to '/'

page 'Sign in' at '/login':
  section 'Sign in' centered, padded:
    heading 'Sign in to the CRO console'
    text 'Use the signup or login form above. After signing in, head to /cro.'

# Tests

test:
  can user submit a deal with rep_name: 'mike.l', customer: 'Beta Co', list_price: 50000, discount_percent: 10
  expect it succeeds

test:
  can user submit a deal with rep_name: 'sarah.j', customer: 'Acme Corp', list_price: 240000, discount_percent: 25
  expect it succeeds

test:
  updating a deal should require login

test:
  creating a deal should require login

test:
  can user approve a deal
