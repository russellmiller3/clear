/*
LAYOUT:
+----------------+-----------------------------------+---------------+
| Sidebar        | Pending queue workbench           | Deal details  |
| Approvals      | Header, tabs, stats, table        | AI summary    |
| Pipeline       | Row actions and sortable columns  | Sticky actions|
+----------------+-----------------------------------+---------------+

DATAFLOW:
Rep form -> POST /api/deals -> Deals table
CRO queue -> GET /api/deals/pending -> table + selected detail panel
Detail panel -> draft summary, risk, recommendation, approve/counter/reject
*/

build for web and javascript backend
database is local memory

# Database

create a Deals table:
  rep_name, required
  rep_email
  customer, required
  customer_email
  account_segment
  deal_type
  list_price (number), default 0
  discount_percent (number), default 0
  status, default 'pending'
  summary
  recommendation
  risk_score (number), default 0
  submitted_label
  approval_rule
  term
  effective_date
  health_signal
  precedent_note
  created_at_date, auto

# Reps, Accounts, ApprovalRules, Integrations
# These tables back the sidebar pages so nav items reach real data instead
# of 404. Cherry-picked from Codex's stashed deal-desk on 2026-04-28.

create a Reps table:
  rep_name, required, unique
  team
  open_requests (number), default 0
  approved_today (number), default 0
  average_discount
  value_at_stake
  risk_flag

create a Accounts table:
  customer, required, unique
  account_segment
  owner
  active_requests (number), default 0
  total_value (number), default 0
  last_decision
  health_signal

create a ApprovalRules table:
  rule_name, required, unique
  threshold
  owner
  status
  last_updated

create a Integrations table:
  system_name, required, unique
  sync_status
  last_sync
  records_synced (number), default 0
  owner

# Approval queue
# The queue primitive auto-generates: deal_decisions audit table,
# deal_notifications outbound queue, GET /api/deals/queue (filtered by
# pending status), GET /api/deal-decisions, GET /api/deal-notifications,
# and PUT /api/deals/:id/<action> for each action below. Each PUT
# requires login, updates deal status, records the decision, and queues
# notifications to the listed roles.

queue for deal:
  reviewer is 'CRO'
  actions: approve, reject, counter, awaiting customer
  notify customer on counter, awaiting customer
  notify rep on approve, reject

# Backend

allow cross-origin requests
allow signup and login
log every request

# Drafter

/*
draft_approval — given a deal, asks the AI to write a CRO-ready summary plus
a clear approve/reject recommendation and a risk score from 1 (low) to 10
(high). Used by the /api/deals/draft endpoint when the CRO clicks the
"draft AI summary" button on a pending row.
*/

define function draft_approval(deal_data):
  drafted = ask claude 'You are a deal-desk analyst writing for the CRO. Given a discount request, write a one-paragraph approval summary. Cover: why the rep wants this discount, the financial impact in dollars, the strategic risk if approved, and a clear approve or reject recommendation. Keep it under 100 words. Be direct.' with deal_data returning JSON text:
    summary
    recommendation
    risk_score (number)
  return drafted

# Endpoints

when user requests data from /api/deals/pending:
  send back all Deals where status is 'pending'

# Filter URLs feeding the sidebar pages.
when user requests data from /api/deals/approved:
  send back all Deals where status is 'approved'

when user requests data from /api/deals/rejected:
  send back all Deals where status is 'rejected'

when user requests data from /api/deals/awaiting:
  send back all Deals where status is 'awaiting'

when user requests data from /api/deals/all:
  send back all Deals

when user requests data from /api/reps:
  send back all Reps

when user requests data from /api/accounts:
  send back all Accounts

when user requests data from /api/approval-rules:
  send back all ApprovalRules

when user requests data from /api/integrations:
  send back all Integrations

when user sends deal to /api/deals:
  requires login
  validate deal:
    rep_name is text, required, min 1, max 100
    customer is text, required, min 1, max 200
    list_price is number, min 0
    discount_percent is number, min 0, max 100
  if deal's discount_percent is greater than 20:
    deal's status is 'pending'
  otherwise:
    deal's status is 'approved'
    deal's recommendation is 'auto'
  new_deal = save deal as new Deal
  send back new_deal with success message

when user sends deal_request to /api/deals/draft:
  requires login
  drafted = draft_approval(deal_request)
  send back drafted

when user updates deal at /api/deals/:id:
  requires login
  save deal to Deals
  send back 'updated' with success message

# The /api/deals/:id/approve URL is now auto-generated by the queue primitive
# above (along with /reject, /counter, /awaiting). Each requires login,
# updates the deal status, records the decision in deal_decisions, and
# queues notifications. Hand-rolled approve URL removed in favor of the
# primitive's version on 2026-04-27.

