build for web and javascript backend
database is local memory

# --- Data Shapes ---

create a Workflows table:
  workflow, required
  step, required
  state
  created_at (timestamp), auto

# --- Agents ---

agent 'Research Agent' receives state:
  set state's research to ask ai 'Research the topic and provide key findings' with state's topic
  send back state

agent 'Writer Agent' receives state:
  set state's draft to ask ai 'Write a draft article based on the research' with state's research
  send back state

agent 'Reviewer Agent' receives state:
  set result to ask ai 'Review this draft for quality. Score 1-10.' with state's draft returning JSON text:
    quality_score (number)
    feedback
  set state's quality_score to result's quality_score
  set state's feedback to result's feedback
  send back state

agent 'Publisher Agent' receives state:
  set state's published to true
  send back state

agent 'Sentiment Agent' receives state:
  set state's sentiment to ask ai 'Rate sentiment 1-10' with state's draft
  send back state

agent 'SEO Agent' receives state:
  set state's seo_score to ask ai 'Rate SEO quality 1-10' with state's draft
  send back state

# --- Workflow (Phases 85-90) ---

workflow 'Content Pipeline' with state:
  save progress to Workflows table
  track workflow progress
  state has:
    topic, required
    research
    draft
    quality_score (number), default 0
    feedback
    sentiment
    seo_score
    published (boolean), default false

  step 'Research' with 'Research Agent'
  step 'Write' with 'Writer Agent'
  repeat until state's quality_score is greater than 8, max 3 times:
    step 'Review' with 'Reviewer Agent'
    if state's quality_score is less than 8:
      step 'Revise' with 'Writer Agent'
  at the same time:
    step 'Sentiment' with 'Sentiment Agent' saves to state's sentiment
    step 'SEO' with 'SEO Agent' saves to state's seo_score
  step 'Publish' with 'Publisher Agent'

# --- API ---

when user calls POST /api/content sending data:
  result = run workflow 'Content Pipeline' with data
  send back result

# --- Frontend ---

page 'Content Pipeline' at '/':
  section 'Create Content':
    'Topic' as text input
    button 'Generate Content':
      send topic to '/api/content'

# --- Tests ---

test 'workflow produces quality content':
  mock claude responding:
    research is 'Key findings about AI'
  mock claude responding:
    draft is 'AI is transforming the world...'
  mock claude responding:
    quality_score = 9
    feedback is 'Excellent article'
  mock claude responding:
    sentiment is 'positive'
  mock claude responding:
    seo_score is '8/10'
