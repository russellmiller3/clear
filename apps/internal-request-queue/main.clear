/*
LAYOUT:
+----------------+-----------------------------------------------+
| Request Queue  | Header: triage workspace                       |
|                +-----------------------------------------------+
| Queues         | New requests + KPI strip                       |
| - New          | +-------------------------+ +---------------+ |
| - All requests | | new request table       | | detail panel  | |
| Teams          | | category / priority     | | triage view   | |
| - IT / HR      | +-------------------------+ +---------------+ |
|                | Submit request form                           |
+----------------+-----------------------------------------------+

DATAFLOW:
Employee -> POST /api/requests -> Requests table
Ops team -> GET /api/requests/new -> table -> detail panel
Ops team -> update selected request -> assigned or resolved
*/

build for web and javascript backend
database is local memory

# Database

create a Requests table:
  title, required
  description
  category, default 'IT'
  priority, default 'Normal'
  submitter, required
  assigned_to
  status, default 'new'
  resolution
  created_at_date, auto

# Triage queue
/*
Auto-generates audit, action URLs, and filtered queue URL.
Each action requires login and records the triage decision.
*/

queue for request:
  reviewer is 'ops'
  actions: assign, resolve

# Backend

## Middleware

allow cross-origin requests
allow signup and login
log every request

## Endpoints

when user requests data from /api/requests:
  send back all Requests

when user requests data from /api/requests/new:
  send back all Requests where status is 'new'

when user requests data from /api/requests/my:
  send back all Requests

when user sends request to /api/requests:
  requires login
  validate request:
    title is text, required, min 1, max 200
    submitter is text, required
  new_request = save request as new Request
  send back new_request with success message

when user updates request at /api/requests/:id:
  requires login
  save request to Requests
  send back 'updated' with success message

## Seed Data

when user sends seed to /api/seed:
  create r1:
    title is 'New laptop - mine is overheating'
    description is 'MacBook keeps shutting down during video calls. Replacement needed.'
    category is 'IT'
    priority is 'High'
    submitter is 'sarah.j'
    status is 'new'
  save r1 as new Request
  create r2:
    title is 'Update direct deposit info'
    description is 'Switched banks last week, need to request payroll.'
    category is 'HR'
    priority is 'Normal'
    submitter is 'mike.l'
    status is 'in_progress'
    assigned_to is 'hr-team'
  save r2 as new Request
  create r3:
    title is 'Replace conference room projector'
    description is 'Projector in Madison room has a dead pixel.'
    category is 'Facilities'
    priority is 'Low'
    submitter is 'alex.p'
    status is 'new'
  save r3 as new Request
  create r4:
    title is 'Reimburse client dinner'
    description is 'Had dinner with 3 people at Acme Corp. Receipt attached.'
    category is 'Finance'
    priority is 'Normal'
    submitter is 'jamie.k'
    status is 'resolved'
    assigned_to is 'ap-team'
    resolution is 'Approved and processed'
  save r4 as new Request
  send back 'seeded' with success message

# Frontend

page 'Request Queue' at '/':
  new_requests is an empty list
  all_requests is an empty list

  on page load:
    send nothing to '/api/seed'
    get new_requests from '/api/requests/new'
    get all_requests from '/api/requests'

  new_count = count of new_requests
  all_count = count of all_requests
  team_count = 4

  section 'App' with style app_layout:

    section 'Sidebar' with style app_sidebar:
      heading 'Requests'

      nav section 'Queues':
        nav item 'New' to '/' with count new_count with icon 'inbox'
        nav item 'All requests' to '/all' with count all_count with icon 'list-checks'

      nav section 'Teams':
        nav item 'IT' to '/team/it' with icon 'monitor'
        nav item 'HR' to '/team/hr' with icon 'users'
        nav item 'Facilities' to '/team/facilities' with icon 'building-2'
        nav item 'Finance' to '/team/finance' with icon 'receipt'

    section 'Main' with style app_main:

      section 'Top' with style app_header:
        heading 'Internal Request Queue'
        text 'Operations / Employee intake'
        button 'Refresh':
          get new_requests from '/api/requests/new'
          get all_requests from '/api/requests'

      section 'Body' with style app_content:

        page header 'New Request Triage':
          subtitle '{new_count} requests awaiting owner assignment'
          actions:
            button 'Refresh':
              get new_requests from '/api/requests/new'
              get all_requests from '/api/requests'

        stat strip:
          stat card 'New':
            value new_count
            delta 'Needs first response'
            sparkline [2, 3, 2, 4, 2]
            icon 'inbox'
          stat card 'All Requests':
            value all_count
            delta 'Across open and resolved work'
            sparkline [3, 4, 5, 5, 4]
            icon 'list-checks'
          stat card 'Teams':
            value team_count
            delta 'IT, HR, Facilities, Finance'
            sparkline [4, 4, 4, 4, 4]
            icon 'users'

        section 'Triage Workbench' as 2 columns:
          section 'New Requests' with style app_table:
            display new_requests as table showing title, category, priority, submitter

          detail panel for selected_request:
            small text 'Select a request to inspect the triage facts.'
            text selected_request's title
            text selected_request's description
            text selected_request's category
            text selected_request's priority
            text selected_request's submitter
            text selected_request's status
            actions:
              button 'Assign':
                change selected_request's status from 'new' to 'assigned'
                update selected_request at /api/requests/:id/assign
                get new_requests from '/api/requests/new'
                get all_requests from '/api/requests'
              button 'Resolve':
                change selected_request's status from 'new' to 'resolved'
                update selected_request at /api/requests/:id/resolve
                get new_requests from '/api/requests/new'
                get all_requests from '/api/requests'

        section 'Submit Request' with style app_card:
          subheading 'Submit Request'
          'Title' as text input saves to title
          'Description' as text input saves to description
          'Category' is a dropdown with ['IT', 'HR', 'Facilities', 'Finance'] saved as a category
          'Priority' is a dropdown with ['Urgent', 'High', 'Normal', 'Low'] saved as a priority
          'Your name' as text input saves to submitter
          button 'Submit':
            send title, description, category, priority, and submitter to '/api/requests'
            get new_requests from '/api/requests/new'
            get all_requests from '/api/requests'
            title is ''
            description is ''

page 'All requests' at '/all':
  on page load:
    get all_requests from '/api/requests'

  all_count = count of all_requests
  new_count = count of all_requests where status is 'new'
  resolved_count = count of all_requests where status is 'resolved'

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      heading 'Requests'
      nav section 'Queues':
        nav item 'New' to '/' with icon 'inbox'
        nav item 'All requests' to '/all' with count all_count with icon 'list-checks'
      nav section 'Teams':
        nav item 'IT' to '/team/it' with icon 'monitor'
        nav item 'HR' to '/team/hr' with icon 'users'
        nav item 'Facilities' to '/team/facilities' with icon 'building-2'
        nav item 'Finance' to '/team/finance' with icon 'receipt'

    section 'Main' with style app_main:
      section 'Top' with style app_header:
        heading 'All requests'
        text 'Operations / All requests'

      section 'Body' with style app_content:
        page header 'Every internal request':
          subtitle '{all_count} total — {new_count} new, {resolved_count} resolved.'

        section 'All Requests' with style app_table:
          display all_requests as table showing title, category, priority, submitter, status

page 'IT requests' at '/team/it':
  on page load:
    get all_requests from '/api/requests'

  it_requests = all_requests where category is 'IT'
