/*
Lead Router - sales intake workbench

LAYOUT:
+-------------+----------------------------------------------+
| Sidebar     | Top bar                                      |
| - New queue +----------------------------------------------+
| - Routing   | Page header                                  |
| - Owners    | Stats: new leads, owners, rules              |
|             | Intake form                                  |
|             | Lead table + selected lead detail panel      |
+-------------+----------------------------------------------+

Lead Router — intake form, apply rules, assign to owner

  ┌──────────┐  submit   ┌──────────┐   rules    ┌──────────┐
  │ Prospect │ ────────► │  Server  │ ─────────► │  Leads   │
  └──────────┘           └──────────┘            └──────────┘
                               │                      │
                               │ route by size        │
                               ▼                      │
                        SMB → Alice                   │
                        Mid → Bob                     │
                        Enterprise → Charlie          │
                                                      │
                          ┌──────────┐                │
                          │   Ops    │ ◄──────────────┘
                          │   View   │
                          └──────────┘
*/

build for web and javascript backend
database is local memory

# Database

create a Leads table:
  name, required
  email, required
  company
  size, default 'SMB'
  source
  assigned_to
  status, default 'new'
  created_at_date, auto

# Backend

## Middleware

allow cross-origin requests
allow signup and login
log every request

## Endpoints

when user requests data from /api/leads:
  send back all Leads

when user requests data from /api/leads/new:
  send back all Leads where status is 'new'

when user sends lead to /api/leads:
  requires login
  rule lead-must-have-name:
    enforce that lead's name is not '', or fail with error message: 'Every lead needs a name field — leads without names cannot be routed'
  rule lead-must-have-email:
    enforce that lead's email is not '', or fail with error message: 'Every lead needs an email address — leads without emails cannot be contacted'
  validate lead:
    name is text, required, min 1, max 100
    email is text, required
    size is text
  route lead by size:
    'SMB' to alice
    'Mid-market' to bob
    'Enterprise' to charlie
    default to alice
  new_lead = save lead as new Lead
  send back new_lead with success message

when user updates lead at /api/leads/:id:
  requires login
  save lead to Leads
  send back 'updated' with success message

## Seed Data

when user sends seed to /api/seed:
  create l1:
    name is 'Priya Shah'
    email is 'priya@acmecorp.com'
    company is 'Acme Corp'
    size is 'Enterprise'
    source is 'webinar'
    assigned_to is 'charlie'
    status is 'new'
  save l1 as new Lead
  create l2:
    name is 'Marcus Jones'
    email is 'mj@shopify-shops.com'
    company is 'Shopify Shops'
    size is 'Mid-market'
    source is 'content'
    assigned_to is 'bob'
    status is 'new'
  save l2 as new Lead
  create l3:
    name is 'Jenna Liu'
    email is 'jenna@tinystudio.co'
    company is 'Tiny Studio'
    size is 'SMB'
    source is 'referral'
    assigned_to is 'alice'
    status is 'new'
  save l3 as new Lead
  create l4:
    name is 'Derek Patel'
    email is 'dp@biginc.com'
    company is 'Big Inc'
    size is 'Enterprise'
    source is 'outbound'
    assigned_to is 'charlie'
    status is 'qualified'
  save l4 as new Lead
  send back 'seeded' with success message

# Frontend

page 'Lead Router' at '/':
  on page load:
    send nothing to '/api/seed'
    get new_leads from '/api/leads/new'

  total = count of new_leads
  owners = 3
  rules = 3

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      heading 'Lead Router'
      nav section 'Queues':
        nav item 'New leads' to '/' with count total with icon 'inbox'
      nav section 'Operations':
        nav item 'Routing rules' to '/routing-rules' with count rules with icon 'route'
        nav item 'Owners' to '/owners' with count owners with icon 'users'

    section 'Main' with style app_main:
      section 'Top' with style app_header:
        heading 'Lead Router'
        text 'Sales ops / intake'

      section 'Content' with style app_content:
        page header 'New lead queue':
          subtitle '{total} leads awaiting follow-up'
          actions:
            button 'Refresh':
              get new_leads from '/api/leads/new'

        small text '{total} new leads, {owners} owners, and {rules} routing rules are live.'

        stat strip:
          stat card 'New Leads':
            value total
            delta 'Live intake queue'
            sparkline [1, 2, 3, 3, 4]
            icon 'inbox'
          stat card 'Owners':
            value owners
            delta 'Alice, Bob, Charlie'
            icon 'users'
          stat card 'Routing Rules':
            value rules
            delta 'Size based assignment'
            icon 'route'

        section 'New Lead' with style app_card:
          subheading 'Add lead'
          'Name' as text input saves to name
          'Email' as text input saves to email
          'Company' as text input saves to company
          'Size' is a dropdown with ['SMB', 'Mid-market', 'Enterprise'] saved as a size
          'Source' as text input saves to source
          button 'Add Lead':
            send name, email, company, size, and source to '/api/leads'
            get new_leads from '/api/leads/new'
            name is ''
            email is ''
            company is ''
            source is ''

        section 'Lead Workbench' as 2 columns:
          section 'New Leads' with style app_table:
            display new_leads as table showing name, company, size, source, assigned_to

          detail panel for selected_lead:
            small text 'Select a lead to inspect the routing decision.'
            text selected_lead's name
            text selected_lead's company
            text selected_lead's source
            text selected_lead's assigned_to

page 'Routing rules' at '/routing-rules':
  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      heading 'Lead Router'
      nav section 'Queues':
        nav item 'New leads' to '/' with icon 'inbox'
      nav section 'Operations':
        nav item 'Routing rules' to '/routing-rules' with icon 'route'
        nav item 'Owners' to '/owners' with icon 'users'

    section 'Main' with style app_main:
      section 'Top' with style app_header:
        heading 'Routing rules'
        text 'Sales ops / routing'

      section 'Content' with style app_content:
        page header 'How leads are routed':
          subtitle 'Each new lead lands with one owner based on company size — and two named rules guard intake quality.'

        section 'Size-based routing' with style app_card:
          subheading 'Owner assignment by company size'
          text 'When a lead is submitted, its size field decides who picks it up.'
          text 'SMB leads → alice'
          text 'Mid-market leads → bob'
          text 'Enterprise leads → charlie'
          text 'No size set → alice (default)'

        section 'Intake guard rules' with style app_card:
          subheading 'Named rules the prover verifies on every push'
          text 'lead-must-have-name — every lead needs a name field; blanks reject with HTTP 403.'
          text 'lead-must-have-email — every lead needs an email; blanks reject with HTTP 403.'
          text 'Both rules carry their name in the rejection body so the audit log attributes refusals by policy, not by line number.'

page 'Owners' at '/owners':
  on page load:
    get all_leads from '/api/leads'

  alice_count = count of all_leads where assigned_to is 'alice'
  bob_count = count of all_leads where assigned_to is 'bob'
  charlie_count = count of all_leads where assigned_to is 'charlie'

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      heading 'Lead Router'
      nav section 'Queues':
        nav item 'New leads' to '/' with icon 'inbox'
      nav section 'Operations':
        nav item 'Routing rules' to '/routing-rules' with icon 'route'
        nav item 'Owners' to '/owners' with icon 'users'

    section 'Main' with style app_main:
      section 'Top' with style app_header:
        heading 'Owners'
        text 'Sales ops / owners'

      section 'Content' with style app_content:
        page header 'Lead owners':
          subtitle 'Three owners pick up new leads. Counts include leads in every status, not just new.'

        stat strip:
          stat card 'Alice':
            value alice_count
            delta 'SMB owner'
            icon 'user'
          stat card 'Bob':
            value bob_count
            delta 'Mid-market owner'
            icon 'user'
          stat card 'Charlie':
            value charlie_count
            delta 'Enterprise owner'
            icon 'user'

        section 'Lead distribution by owner' with style app_table:
          display all_leads as table showing name, company, size, assigned_to, status

# Tests

/*
Real business-rule coverage. Each test exercises one of the named
rules in the POST /api/leads handler. Tests below check the rule
NAMES the prover and audit PDF report on.
*/

test 'happy path: full lead is accepted':
  can user submit a lead with name: 'Test', email: 'test@x.com', size: 'SMB'
  expect it succeeds
  expect response has id

test 'rule lead-must-have-name: blank name is rejected':
  can user submit a lead with name: '', email: 'test@x.com', size: 'SMB'
  expect it is rejected

test 'rule lead-must-have-email: blank email is rejected':
  can user submit a lead with name: 'Test', email: '', size: 'SMB'
  expect it is rejected

test 'auth: updating a lead requires login':
  updating a lead should require login
