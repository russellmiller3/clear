/*
Lead Router - sales intake workbench

LAYOUT:
+-------------+----------------------------------------------+
| Sidebar     | Top bar                                      |
| - New queue +----------------------------------------------+
| - Routing   | Page header                                  |
| - Owners    | Stats: new leads, owners, rules              |
|             | Intake form                                  |
|             | Lead table + selected lead detail panel      |
+-------------+----------------------------------------------+

Lead Router — intake form, apply rules, assign to owner

  ┌──────────┐  submit   ┌──────────┐   rules    ┌──────────┐
  │ Prospect │ ────────► │  Server  │ ─────────► │  Leads   │
  └──────────┘           └──────────┘            └──────────┘
                               │                      │
                               │ route by size        │
                               ▼                      │
                        SMB → Alice                   │
                        Mid → Bob                     │
                        Enterprise → Charlie          │
                                                      │
                          ┌──────────┐                │
                          │   Ops    │ ◄──────────────┘
                          │   View   │
                          └──────────┘
*/

build for web and javascript backend
database is local memory

# Database

create a Leads table:
  name, required
  email, required
  company
  size, default 'SMB'
  source
  assigned_to
  status, default 'new'
  created_at_date, auto

# Backend

## Middleware

allow cross-origin requests
allow signup and login
log every request

## Endpoints

when user requests data from /api/leads:
  send back all Leads

when user requests data from /api/leads/new:
  send back all Leads where status is 'new'

when user sends lead to /api/leads:
  validate lead:
    name is text, required, min 1, max 100
    email is text, required
    size is text
  route lead by size:
    'SMB' to alice
    'Mid-market' to bob
    'Enterprise' to charlie
    default to alice
  new_lead = save lead as new Lead
  send back new_lead with success message

when user updates lead at /api/leads/:id:
  requires login
  save lead to Leads
  send back 'updated' with success message

## Seed Data

when user sends seed to /api/seed:
  create l1:
    name is 'Priya Shah'
    email is 'priya@acmecorp.com'
    company is 'Acme Corp'
    size is 'Enterprise'
    source is 'webinar'
    assigned_to is 'charlie'
    status is 'new'
  save l1 as new Lead
  create l2:
    name is 'Marcus Jones'
    email is 'mj@shopify-shops.com'
    company is 'Shopify Shops'
    size is 'Mid-market'
    source is 'content'
    assigned_to is 'bob'
    status is 'new'
  save l2 as new Lead
  create l3:
    name is 'Jenna Liu'
    email is 'jenna@tinystudio.co'
    company is 'Tiny Studio'
    size is 'SMB'
    source is 'referral'
    assigned_to is 'alice'
    status is 'new'
  save l3 as new Lead
  create l4:
    name is 'Derek Patel'
    email is 'dp@biginc.com'
    company is 'Big Inc'
    size is 'Enterprise'
    source is 'outbound'
    assigned_to is 'charlie'
    status is 'qualified'
  save l4 as new Lead
  send back 'seeded' with success message

# Frontend

page 'Lead Router' at '/':
  on page load:
    send nothing to '/api/seed'
    get new_leads from '/api/leads/new'

  total = count of new_leads
  owners = 3
  rules = 3

  section 'App' with style app_layout:
    section 'Sidebar' with style app_sidebar:
      heading 'Lead Router'
      nav section 'Queues':
        nav item 'New leads' to '/' with count total with icon 'inbox'
      nav section 'Operations':
        nav item 'Routing rules' to '/' with count rules with icon 'route'
        nav item 'Owners' to '/' with count owners with icon 'users'

    section 'Main' with style app_main:
      section 'Top' with style app_header:
        heading 'Lead Router'
        text 'Sales ops / intake'

      section 'Content' with style app_content:
        page header 'New lead queue':
          subtitle '{total} leads awaiting follow-up'
          actions:
            button 'Refresh':
              get new_leads from '/api/leads/new'

        small text '{total} new leads, {owners} owners, and {rules} routing rules are live.'

        stat strip:
          stat card 'New Leads':
            value total
            delta 'Live intake queue'
            sparkline [1, 2, 3, 3, 4]
            icon 'inbox'
          stat card 'Owners':
            value owners
            delta 'Alice, Bob, Charlie'
            icon 'users'
          stat card 'Routing Rules':
            value rules
            delta 'Size based assignment'
            icon 'route'

        section 'New Lead' with style app_card:
          subheading 'Add lead'
          'Name' as text input saves to name
          'Email' as text input saves to email
          'Company' as text input saves to company
          'Size' is a dropdown with ['SMB', 'Mid-market', 'Enterprise'] saved as a size
          'Source' as text input saves to source
          button 'Add Lead':
            send name, email, company, size, and source to '/api/leads'
            get new_leads from '/api/leads/new'
            name is ''
            email is ''
            company is ''
            source is ''

        section 'Lead Workbench' as 2 columns:
          section 'New Leads' with style app_table:
            display new_leads as table showing name, company, size, source, assigned_to

          detail panel for selected_lead:
            small text 'Select a lead to inspect the routing decision.'
            text selected_lead's name
            text selected_lead's company
            text selected_lead's source
            text selected_lead's assigned_to

# Tests

test:
  can user submit a lead with name is 'Test', email is 'test@x.com', size is 'SMB'
  expect it succeeds
  expect response has id

test:
  updating a lead should require login
