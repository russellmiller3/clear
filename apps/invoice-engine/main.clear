build for javascript backend

# Invoice Engine -- backend-only stress test
# Tests: status machine, computed totals, conditional logic,
# multi-table CRUD, business rules, no frontend

# ============================================================
# Database
# ============================================================

database is local memory

create a Clients table:
  name, required
  email, required, unique
  company
  phone
  created_at_date, auto

create a Invoices table:
  client_id, required
  invoice_number, required, unique
  status, default 'draft'
  due_date
  subtotal (number), default 0
  tax_rate (number), default 0
  tax_amount (number), default 0
  total (number), default 0
  notes
  created_at_date, auto

create a LineItems table:
  invoice_id, required
  description, required
  quantity (number), required
  unit_price (number), required
  line_total (number), default 0
  created_at_date, auto

create a Payments table:
  invoice_id, required
  amount (number), required
  method, required
  reference
  created_at_date, auto

create a AuditLog table:
  entity_type, required
  entity_id, required
  action, required
  detail
  created_at_date, auto

# ============================================================
# Config
# ============================================================

allow cross-origin requests
log every request

# ============================================================
# Clients
# ============================================================

when user calls GET /api/clients:
  all_clients = get all Clients
  send back all_clients

when user calls GET /api/clients/:id:
  define client as: look up records in Clients table where id is incoming's id
  if client is nothing then send back 'Client not found' status 404
  send back client

when user calls POST /api/clients sending client:
  requires login
  validate client:
    name is text, required, min 1, max 200
    email is text, required, matches email
    company is text
    phone is text
  new_client = save client as new Client
  send back new_client with success message

when user calls PUT /api/clients/:id sending client:
  requires login
  validate client:
    name is text
    email is text
    company is text
    phone is text
  save client to Clients
  send back 'updated' with success message

when user calls DELETE /api/clients/:id:
  requires login
  requires role 'admin'
  delete the Client with this id
  send back 'deleted' with success message

# ============================================================
# Invoices
# ============================================================

when user calls GET /api/invoices:
  all_invoices = get all Invoices
  send back all_invoices

when user calls GET /api/invoices/:id:
  define invoice as: look up records in Invoices table where id is incoming's id
  if invoice is nothing then send back 'Invoice not found' status 404
  send back invoice

when user calls POST /api/invoices sending invoice:
  requires login
  validate invoice:
    client_id is text, required
    invoice_number is text, required, min 1, max 50
    due_date is text
    tax_rate is number
    notes is text
  new_invoice = save invoice as new Invoice
  send back new_invoice with success message

# --- Status transitions ---
# Valid transitions: draft->sent, sent->paid, sent->overdue, draft->cancelled, sent->cancelled

when user calls PUT /api/invoices/:id/send:
  requires login
  define invoice as: look up records in Invoices table where id is incoming's id
  guard invoice is not nothing or 'Invoice not found'
  guard invoice's status is 'draft' or 'Only draft invoices can be sent'
  invoice's status is 'sent'
  save invoice to Invoices
  send back 'sent' with success message

when user calls PUT /api/invoices/:id/pay sending billing:
  requires login
  validate billing:
    amount is number, required
    method is text, required
    reference is text
  define invoice as: look up records in Invoices table where id is incoming's id
  guard invoice is not nothing or 'Invoice not found'
  guard invoice's status is 'sent' or 'Only sent invoices can be marked as paid'
  billing's invoice_id is incoming's id
  new_payment = save billing as new Payment
  invoice's status is 'paid'
  save invoice to Invoices
  send back 'paid' with success message

when user calls PUT /api/invoices/:id/cancel:
  requires login
  define invoice as: look up records in Invoices table where id is incoming's id
  guard invoice is not nothing or 'Invoice not found'
  guard invoice's status is not 'paid' or 'Paid invoices cannot be cancelled'
  invoice's status is 'cancelled'
  save invoice to Invoices
  send back 'cancelled' with success message

when user calls DELETE /api/invoices/:id:
  requires login
  requires role 'admin'
  define invoice as: look up records in Invoices table where id is incoming's id
  guard invoice is not nothing or 'Invoice not found'
  guard invoice's status is 'draft' or 'Only draft invoices can be deleted'
  delete the Invoice with this id
  send back 'deleted' with success message

# ============================================================
# Line Items
# ============================================================

when user calls GET /api/line-items:
  all_items = get all LineItems
  send back all_items

when user calls POST /api/line-items sending line_item:
  requires login
  validate line_item:
    invoice_id is text, required
    description is text, required, min 1, max 500
    quantity is number, required
    unit_price is number, required
  new_item = save line_item as new LineItem
  send back new_item with success message

when user calls DELETE /api/line-items/:id:
  requires login
  delete the LineItem with this id
  send back 'deleted' with success message

# ============================================================
# Payments
# ============================================================

when user calls GET /api/payments:
  requires login
  all_payments = get all Payments
  send back all_payments

# ============================================================
# Audit Log
# ============================================================

when user calls GET /api/audit:
  requires login
  requires role 'admin'
  all_logs = get all AuditLog
  send back all_logs

# ============================================================
# Reports (read-only computed endpoints)
# ============================================================

when user calls GET /api/reports/summary:
  requires login
  all_invoices = get all Invoices
  all_payments = get all Payments
  send back all_invoices

# ============================================================
# Health
# ============================================================

when user calls GET /api/health:
  send back 'ok'
