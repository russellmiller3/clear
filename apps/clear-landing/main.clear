build for web
theme 'ivory'

# Clear Language -- Landing Page
# Target: Freelancers and small agencies who build the same CRUD apps repeatedly
# Uses built-in DaisyUI presets: hero, section_light, section_dark, card, code_box

# --- Hero ---

page 'Clear Language' at '/':
  section 'Hero' with style hero:
    heading 'Build client apps in minutes, not weeks.'
    subheading 'Tested templates. AI agents. One readable file.'
    text 'Pick a template. Customize it. Deploy it. Charge the client.'
    text 'The compiler handles auth, validation, security, and testing. You handle the invoice.'
    link 'See Examples' to '/examples'
    link 'Get Started' to '/start'

  section 'Problem' with style section_light:
    heading 'You build the same 5 apps over and over'
    text 'CRM. Client portal. Dashboard. Booking system. Invoice tool. Every client wants a version of the same thing.'
    text 'You spend 2 weeks on boilerplate: auth, validation, CRUD endpoints, error handling. The client-specific part takes 2 hours.'
    text 'Then something breaks in production and you spend the weekend debugging code you wrote 6 months ago.'

  section 'Solution' with style section_dark:
    heading 'Start from a tested template. Ship in an afternoon.'
    text 'Clear is a readable programming language that compiles to production JavaScript or Python.'
    text 'Every template has been compiled, deployed, and tested end-to-end. Auth works. Validation works. Error handling works. Security is enforced by the compiler -- not by your memory at 11pm.'
    text 'Customize the template for your client. The compiler catches your mistakes before they reach production.'

  section 'How' with style section_light:
    heading 'How It Works'
    subheading '1. Pick a template'
    text 'Invoice engine, project manager, booking system, CRM, ecommerce API, blog, SaaS with billing. All tested.'
    subheading '2. Customize in plain English'
    text 'Change field names, add endpoints, modify validation rules. Each line does one thing. No frameworks to learn.'
    subheading '3. Compile and deploy'
    text 'One command generates a production Express or FastAPI server with auth, validation, CRUD, and error handling.'
    subheading '4. Charge the client'
    text 'Your client gets a working app. You get paid. When they want changes, you read the Clear file and make them in minutes.'

  section 'Example' with style section_dark:
    heading 'A Client Invoice System in 30 Lines'
    text 'This is a real, working API. Auth, validation, CRUD, data persistence. Compiles to Express.js.'
    code block 'build for javascript backend\n\ncreate an Invoices table:\n  client is text, required\n  amount (number), required\n  status, default "draft"\n  due_date\n  created_at_date, auto\n\nwhen user calls POST /api/invoices sending invoice:\n  requires auth\n  validate invoice:\n    client is text, required\n    amount is number, required\n  set saved to save invoice as new Invoice\n  send back saved with success message\n\nwhen user calls GET /api/invoices:\n  requires auth\n  set all_invoices to get all Invoices\n  send back all_invoices\n\nwhen user calls PUT /api/invoices/:id sending updates:\n  requires auth\n  set updated to update Invoice with this id using updates\n  send back updated'
    text 'Change "Invoices" to "Bookings", adjust the fields, deploy. New client, same quality.'

  section 'Agents' with style section_light:
    heading 'AI Agents Built In'
    text 'Clear apps can call AI models mid-flow. Score leads, classify support tickets, moderate content, summarize documents -- all from readable code.'
    code block 'agent \'Lead Scorer\' receiving lead:\n  check lead\'s company is not missing, otherwise error \'Company is required\'\n  set lead\'s score to ask ai \'Rate 1-10 for enterprise potential.\' with lead\'s company\n  send back lead\n\nwhen user calls POST /api/score sending lead_data:\n  validate lead_data:\n    company is text, required\n    email is text, required\n  set scored to call \'Lead Scorer\' with lead_data\n  set saved to save scored as new Lead\n  send back saved with success message'
    text 'The prompt is visible in the source. Your client can read it. You can audit it. No black-box AI.'
    text 'Chain multiple agents into pipelines: screen, then score, then summarize, then save.'

  section 'Compiler' with style section_dark:
    heading 'Bugs the compiler catches for you'
    text 'Auth missing on a DELETE endpoint? Compiler error.'
    text 'Validation missing a required field? Compiler error.'
    text 'User data exposed without row-level security? Compiler error.'
    text 'Every bug the compiler catches is a bug your client never sees. Every fix improves every app.'

  section 'Compare' with style section_light:
    heading 'Clear vs the alternatives'
    subheading 'vs Lovable / Bolt / v0'
    text 'Those tools generate code you cannot read. When it breaks, you are stuck. Clear generates readable source from a readable blueprint. You own both.'
    subheading 'vs hiring a developer'
    text 'A developer builds one app at a time. Clear templates let you build five apps a week with the same quality.'
    subheading 'vs doing it yourself in Express/Next.js'
    text 'You already know how. But you also know that auth, validation, error handling, and security take 80% of the time. The compiler does that part.'

  section 'CTA' with style hero:
    heading 'Ship your next client app this week.'
    text 'Pick a template. Customize it. Deploy it.'
    text 'Your clients get tested, secure apps. You get your weekends back.'
    link 'Get Started' to '/start'

# --- Examples Page ---

page 'Examples' at '/examples':
  section 'Overview' with style section_light:
    heading 'Deployed Apps Built with Clear'
    text 'Every app below compiles with zero errors and passes end-to-end tests.'

  section 'APIs' with style section_dark:
    heading 'Backend APIs'
    text 'Invoice engine -- full CRUD with auth, validation, foreign keys, computed fields (27 E2E tests)'
    text 'Ecommerce API -- products, orders, customers, inventory tracking (16 E2E tests)'
    text 'Project manager -- projects, tasks, team members, status tracking (36 E2E tests)'
    text 'Blog API -- posts, users, comments with auth and validation (14 E2E tests)'
    text 'SaaS billing -- Stripe checkout, subscription management, usage limits'
    text 'Chat backend -- rooms, messages, auth, real-time subscriptions'

  section 'Agents' with style section_light:
    heading 'AI Agent Apps'
    text 'Lead scorer -- AI rates companies for enterprise potential, saves to database'
    text 'Content moderator -- AI classifies content as safe/unsafe with reasoning'
    text 'Hiring pipeline -- 3-agent chain: screen, score, summarize candidates'
    text 'All agent apps use BYOK (bring your own key). Your API key, direct to Anthropic. No markup.'

  section 'FullStack' with style section_dark:
    heading 'Full-Stack Apps'
    text 'Todo app -- reactive frontend + REST backend, 37 lines total'
    text 'Project manager -- dashboard with tables, forms, status filters'
    text 'URL shortener -- create, redirect, track clicks'

  section 'Infra' with style section_light:
    heading 'Infrastructure'
    text 'Every compiled app includes: Express/FastAPI server, JSON body parsing, error handling, graceful shutdown.'
    text 'Auth: JWT tokens, role-based access, middleware. Database: local memory, PostgreSQL, SQLite.'
    text 'Rate limiting, CORS, request logging, webhook signature verification, file uploads.'
    text 'Auto-generated E2E test scripts for every endpoint.'

# --- Get Started Page ---

page 'Get Started' at '/start':
  section 'Start' with style card:
    heading 'Install Clear'
    text 'npm install -g clear-lang'
    divider
    heading 'Build from a template'
    code block 'clear init my-app --template invoice-engine\ncd my-app\nclear build main.clear\nnode server.js'
    divider
    heading 'Or start from scratch'
    code block 'clear init my-app\ncd my-app\n# edit main.clear\nclear build main.clear\nnode server.js'
    divider
    heading 'Deploy'
    code block 'clear package main.clear --out deploy/\n# push to Vercel, Railway, or any Node.js host'
    divider
    heading 'Your first 5 minutes'
    text 'Start with the invoice template. Change the table name and fields to match your client. Build. Deploy. Done.'
    text 'The compiler handles auth, validation, CRUD, error handling, and security. You write the business logic.'
