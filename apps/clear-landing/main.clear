build for web
theme 'ivory'

# Clear Language -- Landing Page
# Target: Freelancers and small agencies who build the same CRUD apps repeatedly
# Uses built-in DaisyUI presets: hero, section_light, section_dark, card, code_box

# --- Hero ---

page 'Clear Language' at '/':
  section 'Nav' with style page_navbar:
    heading 'Clear'
    link 'Examples' to '/examples'
    link 'Docs' to '/start'
    button 'Get Started':
      show 'nav cta clicked'

  section 'Hero' with style hero:
    heading 'Build client apps in minutes, not weeks.'
    subheading 'Tested templates. AI agents. One readable file.'
    text 'Pick a template. Customize it. Deploy it. Charge the client.'
    text 'The compiler handles auth, validation, security, and testing. You handle the invoice.'
    link 'See Examples' to '/examples'
    link 'Get Started' to '/start'

  section 'Problem' with style section_light:
    heading 'You build the same 5 apps over and over'
    text 'CRM. Client portal. Dashboard. Booking system. Invoice tool. Every client wants a version of the same thing.'
    text 'You spend 2 weeks on boilerplate: auth, validation, CRUD endpoints, error handling. The client-specific part takes 2 hours.'
    text 'Then something breaks in production and you spend the weekend debugging code you wrote 6 months ago.'

  section 'Solution' with style section_dark:
    heading 'Start from a tested template. Ship in an afternoon.'
    text 'Clear is a readable programming language that compiles to production JavaScript or Python.'
    text 'Every template has been compiled, deployed, and tested end-to-end. Auth works. Validation works. Error handling works. Security is enforced by the compiler -- not by your memory at 11pm.'
    text 'Customize the template for your client. The compiler catches your mistakes before they reach production.'

  section 'How' with style section_light:
    heading 'How It Works'
    subheading '1. Pick a template'
    text 'Invoice engine, project manager, booking system, CRM, ecommerce API, blog, SaaS with billing. All tested.'
    subheading '2. Customize in plain English'
    text 'Change field names, add endpoints, modify validation rules. Each line does one thing. No frameworks to learn.'
    subheading '3. Compile and deploy'
    text 'One command generates a production Express or FastAPI server with auth, validation, CRUD, and error handling.'
    subheading '4. Charge the client'
    text 'Your client gets a working app. You get paid. When they want changes, you read the Clear file and make them in minutes.'

  section 'Example' with style section_dark:
    heading 'A Client Invoice System in 30 Lines'
    text 'This is a real, working API. Auth, validation, CRUD, data persistence. Compiles to Express.js.'
    code block 'build for javascript backend\n\ncreate an Invoices table:\n  client is text, required\n  amount (number), required\n  status, default "draft"\n  due_date\n  created_at_date, auto\n\nwhen user calls POST /api/invoices sending invoice:\n  requires login\n  validate invoice:\n    client is text, required\n    amount is number, required\n  set saved to save invoice as new Invoice\n  send back saved with success message\n\nwhen user calls GET /api/invoices:\n  requires login\n  set all_invoices to get all Invoices\n  send back all_invoices\n\nwhen user calls PUT /api/invoices/:id sending updates:\n  requires login\n  set updated to update Invoice with this id using updates\n  send back updated'
    text 'Change "Invoices" to "Bookings", adjust the fields, deploy. New client, same quality.'

  section 'Agents' with style section_light:
    heading 'AI Agents Built In'
    text 'Clear apps can call AI models mid-flow. Score leads, classify support tickets, moderate content, summarize documents -- all from readable code.'
    code block 'agent \'Lead Scorer\' receives lead:\n  check lead\'s company is not missing, otherwise error \'Company is required\'\n  set lead\'s score to ask ai \'Rate 1-10 for enterprise potential.\' with lead\'s company\n  send back lead\n\nwhen user calls POST /api/score sending lead_data:\n  validate lead_data:\n    company is text, required\n    email is text, required\n  set scored to call \'Lead Scorer\' with lead_data\n  set saved to save scored as new Lead\n  send back saved with success message'
    text 'The prompt is visible in the source. Your client can read it. You can audit it. No black-box AI.'
    text 'Chain multiple agents into pipelines: screen, then score, then summarize, then save.'

  section 'Compiler' with style section_dark:
    heading 'The compiler catches bugs before your client does'
    text 'Auth missing on a DELETE endpoint? Compiler error.'
    text 'Validation missing a required field? Compiler error.'
    text 'User data exposed without row-level security? Compiler error.'
    text 'Inline API secret in your source code? Compiler error.'
    text 'Every bug the compiler catches is a bug your client never sees. Every fix improves every app on the next build.'

  section 'Translate' with style section_light:
    heading 'When bugs happen, the AI fixes them'
    text 'AI-generated code has 1.7x more bugs than human-written code (OWASP 2026). 86% of AI code fails basic XSS defense. 60% of bugs are invisible -- the code runs but produces wrong output.'
    text 'Clear solves this with a runtime error translator. When compiled code throws an error, the app tells the AI exactly what went wrong, which Clear file and line caused it, and how to fix it.'
    subheading 'Three levels of context'
    text 'Level 1 (production): The user sees "Something went wrong." No database internals leaked.'
    text 'Level 2 (development): The AI sees the Clear source line, a plain-English hint, and a suggested fix -- a minimal diff that solves the problem.'
    text 'Level 3 (deep debug): Full schema context, sanitized request data, cross-file dependency map. PII is auto-redacted.'
    subheading 'The AI reads the error. The AI writes the fix. You review it.'
    text 'The error translator gives AI agents the same context a senior developer would have: what tables exist, what fields are required, which file defined the endpoint, and what the frontend is sending. No more guessing.'

  section 'Diagrams' with style section_dark:
    heading 'Every compiled file documents itself'
    text 'The compiler auto-generates an architecture diagram at the top of every compiled file. Tables, endpoints, auth requirements, page routes, and data flow -- all visible at a glance.'
    text 'The diagram regenerates on every build. It cannot be stale. It is the intent file for your app.'
    code block '// TABLES:\n//   Contacts: name*, email*!, company, status (line 12)\n//   Deals: contact_id*, title*, value, stage (line 22)\n//\n// ENDPOINTS:\n//   GET /api/contacts (line 35)\n//   POST /api/contacts [auth] (line 40)\n//   PUT /api/contacts/:id [auth] (line 55)\n//\n// PAGES:\n//   \'CRM Dashboard\' at / (line 70)\n//\n// DATAFLOW: Frontend --> API --> Database'
    text 'An AI agent opening any compiled file instantly understands the entire app without reading a single line of business logic.'

  section 'APIs' with style section_light:
    heading 'Call any API. Stripe, SendGrid, Twilio built in.'
    text 'Connect to any REST API with call api -- custom headers, auth, body, timeout. Or use a service preset with zero config.'
    code block 'charge via stripe:\n  amount = 2000\n  currency is \'usd\'\n  token is payment_token\n\nsend email via sendgrid:\n  to is customer\'s email\n  subject is \'Invoice sent\'\n  body is email_body\n\nsend sms via twilio:\n  to is customer\'s phone\n  body is \'Your booking is confirmed\''
    text 'Set your API key as an environment variable. The compiler refuses to compile inline secrets.'
    text 'Generic API calls work too -- call any URL with custom headers and auth for services we do not have presets for yet.'

  section 'AI' with style section_dark:
    heading 'First-class AI integration'
    text 'Call Claude directly from your backend. Structured output, model selection, and bring-your-own-key.'
    code block 'answer = ask claude \'Summarize this article\' with article_text\n\nresult = ask claude \'Analyze this lead\' with data returning:\n  score (number)\n  reasoning\n  qualified (boolean)\n\nanswer = ask claude \'Quick answer\' with data using \'claude-haiku-4-5-20251001\''
    text 'The prompt is in the source code. Your client can read it. You can audit it. No black-box AI.'

  section 'Compare' with style section_light:
    heading 'Clear vs the alternatives'
    subheading 'vs Lovable / Bolt / v0'
    text 'Those tools generate code you cannot read. When it breaks, you are stuck. Clear generates readable source from a readable blueprint. When it breaks, the error tells you exactly which line to fix.'
    subheading 'vs Cursor / Copilot / AI coding assistants'
    text 'AI assistants write code with 1.7x more bugs and no way to trace errors back to intent. Clear compiles to self-documenting output with architecture diagrams, source line mapping, and suggested fixes. The AI assistant that wrote the bug can read the error and fix it autonomously.'
    subheading 'vs hiring a developer'
    text 'A developer builds one app at a time. Clear templates let you build five apps a week with the same quality. And when the developer leaves, the code is still readable.'
    subheading 'vs doing it yourself in Express/Next.js'
    text 'You already know how. But you also know that auth, validation, error handling, and security take 80% of the time. The compiler does that part -- and catches the OWASP Top 10 at compile time.'

  section 'CTA' with style hero:
    heading 'Ship your next client app this week.'
    text 'Pick a template. Customize it. Deploy it.'
    text 'Your clients get tested, secure apps. You get your weekends back.'
    link 'Get Started' to '/start'

# --- Examples Page ---

page 'Examples' at '/examples':
  section 'Overview' with style section_light:
    heading 'Deployed Apps Built with Clear'
    text 'Every app below compiles with zero errors and passes end-to-end tests.'

  section 'APIs' with style section_dark:
    heading 'Backend APIs'
    text 'Invoice engine -- full CRUD with auth, validation, foreign keys, computed fields (27 E2E tests)'
    text 'Ecommerce API -- products, orders, customers, inventory tracking (16 E2E tests)'
    text 'Project manager -- projects, tasks, team members, status tracking (36 E2E tests)'
    text 'Blog API -- posts, users, comments with auth and validation (14 E2E tests)'
    text 'SaaS billing -- Stripe checkout, subscription management, usage limits'
    text 'Chat backend -- rooms, messages, auth, real-time subscriptions'

  section 'Agents' with style section_light:
    heading 'AI Agent Apps'
    text 'Lead scorer -- AI rates companies for enterprise potential, saves to database'
    text 'Content moderator -- AI classifies content as safe/unsafe with reasoning'
    text 'Hiring pipeline -- 3-agent chain: screen, score, summarize candidates'
    text 'All agent apps use BYOK (bring your own key). Your API key, direct to Anthropic. No markup.'

  section 'FullStack' with style section_dark:
    heading 'Full-Stack Apps (33 templates)'
    text 'CRM -- contacts, deals, pipeline chart, debounced search, midnight theme'
    text 'CRM Pro -- 5 tables, compound unique constraints, SSE streaming, multi-file with reusable components'
    text 'Invoice -- clients, invoices, line items, full CRUD with inline edit and delete'
    text 'Booking -- services, appointments, confirmations, ivory theme'
    text 'Project manager -- teams, projects, tasks, comments, role-based access'
    text 'Plus: todo, dashboard, URL shortener, ecommerce, SaaS billing, chat, and 20 more.'

  section 'Infra' with style section_light:
    heading 'Production infrastructure, zero config'
    text 'Every compiled app includes: Express/FastAPI server, error handling with source line mapping, graceful shutdown.'
    text 'Auth: HMAC-signed tokens, role-based access, middleware. Database: local memory, PostgreSQL, Supabase.'
    text 'External APIs: Stripe payments, SendGrid email, Twilio SMS, plus generic call api for any REST endpoint.'
    text 'Security: inline secret detection, SSRF blocking, auth enforcement on write endpoints, seed endpoint production guards.'
    text 'Auto-generated architecture diagrams and E2E test scripts for every endpoint.'

# --- Get Started Page ---

page 'Get Started' at '/start':
  section 'Start' with style card:
    heading 'Install Clear'
    text 'npm install -g clear-lang'
    divider
    heading 'Build from a template'
    code block 'clear init my-app --template invoice-engine\ncd my-app\nclear build main.clear\nnode server.js'
    divider
    heading 'Or start from scratch'
    code block 'clear init my-app\ncd my-app\n# edit main.clear\nclear build main.clear\nnode server.js'
    divider
    heading 'Deploy'
    code block 'clear package main.clear --out deploy/\n# push to Vercel, Railway, or any Node.js host'
    divider
    heading 'Your first 5 minutes'
    text 'Start with the invoice template. Change the table name and fields to match your client. Build. Deploy. Done.'
    text 'The compiler handles auth, validation, CRUD, error handling, and security. You write the business logic.'
