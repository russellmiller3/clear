# CRM Pro -- contacts, deals, pipeline, activity log, and revenue tracking
# │ Sidebar  │  Header [Search]     [New Contact]│
# │          ├──────────────────────────────────┤
# │ Dashboard│  ┌────────┐┌────────┐┌──────────┐│
# │ Contacts │  │Contacts││ Deals  ││ Revenue  ││
# │ Deals    │  │  247   ││  18    ││ $142,300 ││
# │ Pipeline │  └────────┘└────────┘└──────────┘│
# │ Activity │  ┌────────────────┐┌────────────┐│
# │ Reports  │  │ Pipeline Chart ││ Recent Log ││
# │          │  └────────────────┘└────────────┘│
# │          │  ┌──────────────────────────────┐│
# │          │  │ Contacts Table (CRUD+search) ││
# │          │  └──────────────────────────────┘│
# └──────────┴──────────────────────────────────┘
#
# DATAFLOW:
# ┌──────────┐   POST /api/contacts    ┌──────────┐   save    ┌────────┐
# │ Frontend │ ──────────────────────> │ Backend  │ ────────> │   DB   │
# │  (forms) │ <────────────────────── │ (server) │ <──────── │(memory)│
# └──────────┘   GET /api/contacts     └──────────┘   query   └────────┘
#      │                                     │
#      │ debounced search ──> GET?q=...      │ PUT /api/deals/:id
#      │ on page load ──> GET all            │ DELETE /api/contacts/:id
#      │ pipeline chart ──> GET /api/deals   │ POST /api/activity

build for web and javascript backend

theme 'midnight'

# Database
database is local memory

create a Contacts table:
  name, required
  email, required, unique
  company
  phone
  status, default 'lead'
  source, default 'direct'
  notes
  last_contacted
  created_at_date, auto

create a Deals table:
  contact_id, required
  title, required
  value (number), default 0
  stage, default 'prospect'
  probability (number), default 10
  expected_close
  notes
  created_at_date, auto

create a Activities table:
  contact_id
  deal_id
  action, required
  detail
  performed_by, default 'system'
  created_at_date, auto

create a Tags table:
  name, required, unique
  color, default 'blue'

create a ContactTags table:
  contact_id, required
  tag_id, required
  one per contact_id and tag_id

# Backend

# Allow the frontend to talk to the backend
allow cross-origin requests

# Print every request to the console for debugging
log every request

# --- Seed data for demo ---
