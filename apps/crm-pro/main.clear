/*
CRM Pro — sales pipeline with companies, contacts, and deal tracking

  ┌──────────┐                     ┌──────────┐
  │ Browser  │ ── CRUD ──────────► │  Server  │
  │ (page)   │ ◄── JSON ────────── │ (Express)│
  └──────────┘                     └─────┬────┘
       │                                 │
       │ search, aggregates              │ CRUD + relationships
       │                                 │
       │                           ┌─────▼──────┐
       │                           │ Companies  │──┐ has many
       │                           └────────────┘  │
       │                           ┌────────────┐  │
       │                           │  Contacts  │◄─┘ belongs to
       │                           └─────┬──────┘──┐ has many
       │                           ┌─────▼──────┐  │
       │                           │   Deals    │◄─┘ belongs to
       │                           └────────────┘
       │                                 │
       └── GET /deals/total ◄── sum(value)
*/

# JUMP TO: Database | Backend | Seed Data | Companies | Contacts | Deals | Search | Frontend

build for web and javascript backend

theme 'midnight'

# Database

database is local memory

create a Companies table:
  name, required
  industry
  website
  contacts has many Contacts

create a Contacts table:
  name, required
  email, required
  phone
  company belongs to Companies
  deals has many Deals

create a Deals table:
  title, required
  value (number), default 0
  stage, default 'lead'
  contact belongs to Contacts

# Backend

## Middleware

allow signup and login
allow cross-origin requests
log every request

## Seed Data

when user sends data to /api/seed:
  create co1:
    name is 'Acme Corp'
    industry is 'Technology'
    website is 'acme.co'
  save co1 as new Company
  create co2:
    name is 'Globex Industries'
    industry is 'Manufacturing'
    website is 'globex.io'
  save co2 as new Company
  create c1:
    name is 'Alice Chen'
    email is 'alice@acme.co'
    phone is '555-0101'
    company is '1'
  save c1 as new Contact
  create c2:
    name is 'Bob Smith'
    email is 'bob@acme.co'
    phone is '555-0102'
    company is '1'
  save c2 as new Contact
  create c3:
    name is 'Carol Davis'
    email is 'carol@globex.io'
    company is '2'
  save c3 as new Contact
  create c4:
    name is 'Dan Wilson'
    email is 'dan@globex.io'
    company is '2'
  save c4 as new Contact
  create d1:
    title is 'Acme Enterprise License'
    value = 45000
    stage is 'negotiation'
    contact is '1'
  save d1 as new Deal
  create d2:
    title is 'Globex Pilot'
    value = 12000
    stage is 'proposal'
    contact is '3'
  save d2 as new Deal
  create d3:
    title is 'Acme Support Contract'
    value = 18000
    stage is 'closed-won'
    contact is '2'
  save d3 as new Deal
  create d4:
    title is 'Globex Annual'
    value = 67300
    stage is 'lead'
    contact is '4'
  save d4 as new Deal
  create d5:
    title is 'Acme Consulting'
    value = 9500
    stage is 'proposal'
    contact is '1'
  save d5 as new Deal
  send back 'seeded' with success message

## Companies CRUD

when user requests data from /api/companies:
  all_companies = get all Companies
  send back all_companies

when user sends data to /api/companies:
  requires login
  validate data:
    name is text, required
    industry is text
    website is text
  new_company = save data as new Company
  send back new_company with success message

when user deletes company at /api/companies/:id:
  requires login
  delete the Company with this id
  send back 'deleted' with success message

## Contacts CRUD

when user requests data from /api/contacts:
  all_contacts = get all Contacts
  send back all_contacts

when user sends data to /api/contacts:
  requires login
  validate data:
    name is text, required
    email is text, required
    phone is text
    company is text
  new_contact = save data as new Contact
  send back new_contact with success message

when user deletes contact at /api/contacts/:id:
  requires login
  delete the Contact with this id
  send back 'deleted' with success message

## Deals CRUD

when user requests data from /api/deals:
  all_deals = get all Deals
  send back all_deals

when user sends data to /api/deals:
  requires login
  validate data:
    title is text, required
    value is number
    stage is text
    contact is text
  new_deal = save data as new Deal
  send back new_deal with success message

when user deletes deal at /api/deals/:id:
  requires login
  delete the Deal with this id
  send back 'deleted' with success message

## Search + Aggregates

when user requests data from /api/search/contacts:
  search_term = incoming's q
  results = search Contacts for search_term
  send back results

when user requests data from /api/deals/total:
  all_deals = get all Deals
  total = sum of value in all_deals
  send back total

# Frontend

page 'CRM Pro' at '/':

  on page load:
    send nothing to '/api/seed'
    get companies from '/api/companies'
    get contacts from '/api/contacts'
    get deals from '/api/deals'

  section 'Layout' with style app_layout:
    section 'Main' with style app_main:
      section 'Header' with style app_header:
        heading 'CRM Pro'

      section 'Body' with style app_content:

        section 'Pipeline' with style app_card:
          subheading 'Pipeline Summary'
          display deals as table showing title, value, stage

        section 'Companies' with style app_card:
          subheading 'Companies'
          display companies as cards showing name, industry

        section 'Contacts' with style app_card:
          subheading 'Contacts'
          'Search contacts...' is a text input saved as a search_query
          when search_query changes after 250ms:
            get contacts from '/api/contacts'
          display contacts as table showing name, email, phone

        section 'Deals' with style app_card:
          subheading 'Deals'
          display deals as table showing title, value, stage

# Tests

test 'user can view all companies':
  can user view all companies

test 'creating a company requires login':
  does creating a company require login

test 'user can view all contacts':
  can user view all contacts

test 'user can view all deals':
  can user view all deals

test 'user can view deal totals':
  can user view all total
