  send back 'seeded' with success message

# --- Contacts CRUD ---
when user calls GET /api/contacts:
  all_contacts = get all Contacts
  send back all_contacts

when user calls POST /api/contacts sending contact_data:
  requires auth
  validate contact_data:
    name is text, required, min 1, max 100
    email is text, required, matches email
    company is text
    phone is text
    status is text
    source is text
    notes is text
  new_contact = save contact_data as new Contact
  send back new_contact with success message

when user calls PUT /api/contacts/:id sending update_data:
  requires auth
  validate update_data:
    name is text
    email is text
    company is text
    phone is text
    status is text
    notes is text
    last_contacted is text
  save update_data to Contacts
  send back 'updated' with success message

when user calls DELETE /api/contacts/:id:
  requires auth
  delete the Contact with this id
  send back 'deleted' with success message

# --- Deals CRUD ---
when user calls GET /api/deals:
  all_deals = get all Deals
  send back all_deals

when user calls POST /api/deals sending deal_data:
  requires auth
  validate deal_data:
    contact_id is text, required
    title is text, required, min 1, max 200
    value is number
    stage is text
    probability is number
    expected_close is text
    notes is text
  new_deal = save deal_data as new Deal
  send back new_deal with success message

when user calls PUT /api/deals/:id sending update_data:
  requires auth
  validate update_data:
    contact_id is text
    title is text
    value is number
    stage is text
    probability is number
    expected_close is text
    notes is text
  save update_data to Deals
  send back 'updated' with success message

when user calls DELETE /api/deals/:id:
  requires auth
  delete the Deal with this id
  send back 'deleted' with success message

# --- Activities ---
when user calls GET /api/activities:
  all_activities = get all Activities
  send back all_activities

when user calls POST /api/activities sending activity_data:
  requires auth
  validate activity_data:
    contact_id is text
    deal_id is text
    action is text, required
    detail is text
    performed_by is text
  new_activity = save activity_data as new Activity
  send back new_activity with success message

# --- Tags ---
when user calls GET /api/tags:
  all_tags = get all Tags
  send back all_tags

when user calls POST /api/tags sending tag_data:
  requires auth
  validate tag_data:
    name is text, required
    color is text
  new_tag = save tag_data as new Tag
  send back new_tag with success message

# Frontend

page 'CRM Pro' at '/':

  on page load:
    send nothing to '/api/seed'
    get contacts from '/api/contacts'
    get deals from '/api/deals'
    get activities from '/api/activities'

  section 'Layout' with style app_layout:

    section 'Nav' with style app_sidebar:
      heading 'CRM Pro'
      divider
      text 'Dashboard'
      text 'Contacts'
      text 'Deals'
      text 'Pipeline'
      text 'Activity'
      text 'Reports'

    section 'Right' with style app_main:
      section 'Top' with style app_header:
        heading 'Dashboard'
        'Search contacts...' is a text input saved as a search_query

      section 'Body' with style app_content:

        # --- Search with debounce ---
        when search_query changes after 250ms:
          get contacts from '/api/contacts'

        # --- Pipeline Chart ---
        section 'Pipeline' with style app_card:
          subheading 'Deal Pipeline'
          chart 'Pipeline' as bar showing deals

        # --- Add Contact Form ---
        section 'New Contact' with style app_card:
          subheading 'Add Contact'
          'Name' is a text input saved as a name
          'Email' is a text input saved as an email
          'Company' is a text input saved as a company
          'Phone' is a text input saved as a phone
          'Status' is a dropdown with ['lead', 'qualified', 'customer', 'churned']
          'Source' is a dropdown with ['direct', 'website', 'referral', 'cold-call', 'event']
          button 'Add Contact':
            send name and email and company and phone and status and source to '/api/contacts'
            get contacts from '/api/contacts'
            name is ''
            email is ''
            company is ''
            phone is ''

        # --- Contacts Table ---
        section 'Contacts' with style app_card:
          subheading 'All Contacts'
          display contacts as table showing name, email, company, status, source with delete and edit

        # --- Add Deal Form ---
        section 'New Deal' with style app_card:
          subheading 'Add Deal'
          'Deal Title' is a text input saved as a title
          'Contact ID' is a text input saved as a contact_id
          'Value ($)' is a number input saved as a value
          'Stage' is a dropdown with ['prospect', 'proposal', 'negotiation', 'closed-won', 'closed-lost']
          'Probability (%)' is a number input saved as a probability
          'Expected Close' is a text input saved as an expected_close
          button 'Add Deal':
            send title and contact_id and value and stage and probability and expected_close to '/api/deals'
            get deals from '/api/deals'
            title is ''
            contact_id is ''

        # --- Deals Table ---
        section 'Deals' with style app_card:
          subheading 'All Deals'
          display deals as table showing title, value, stage, probability, expected_close with delete and edit

        # --- Activity Log ---
        section 'Activity' with style app_card:
          subheading 'Recent Activity'
          display activities as table showing action, detail, performed_by

        # --- Log Activity ---
        section 'Log Activity' with style app_card:
          subheading 'Log Activity'
          'Contact ID' is a text input saved as an activity_contact_id
          'Action' is a dropdown with ['Email sent', 'Call logged', 'Meeting held', 'Note added', 'Deal updated']
          'Detail' is a text area saved as an activity_detail
          button 'Log':
            send activity_contact_id and action and activity_detail to '/api/activities'
            get activities from '/api/activities'
            activity_detail is ''
