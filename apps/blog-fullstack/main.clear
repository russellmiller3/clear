/*
Blog Fullstack — content publishing with authors, categories, and search

  ┌──────────┐   GET/POST/DELETE   ┌──────────┐
  │ Browser  │ ─────────────────►  │  Server  │
  │ (blog)   │ ◄─────────────────  │ (Express)│
  └──────────┘    JSON + HTML      └─────┬────┘
                                         │
                                    ┌────▼─────┐
                                    │ Authors  │──┐ has many
                                    └──────────┘  │
                                    ┌──────────┐  │  ┌────────────┐
                                    │  Posts   │◄─┘  │ Categories │
                                    │          │◄────┘ has many
                                    └──────────┘
                                         │
                                    Auth (JWT)
                                    Search (keyword)
                                    Seed (demo data)
*/

build for web and javascript backend
theme 'ivory'

# Database

database is local memory

create an Authors table:
  name, required
  email, required, unique
  posts has many Posts

create a Categories table:
  name, required, unique
  posts has many Posts

create a Posts table:
  title, required
  body, required
  excerpt
  image_url
  created_at_date, auto
  author belongs to Authors
  category belongs to Categories

# Backend

## Middleware

allow cross-origin requests
allow signup and login
log every request

## Endpoints

when user requests data from /api/authors:
  send back all Authors

when user requests data from /api/categories:
  send back all Categories

when user requests data from /api/posts:
  send back all Posts

when user requests data from /api/posts/:id:
  post = look up records in Posts table where id is incoming's id
  if post is nothing then send back 'Post not found' status 404
  send back post

when user sends post to /api/posts:
  validate post:
    title is text, required, min 1, max 200
    body is text, required, min 1
  new_post = save post as new Post
  send back new_post

when user deletes post at /api/posts/:id:
  requires login
  delete the Post with this id
  send back 'deleted'

when user requests data from /api/search:
  results = search Posts for incoming's q
  send back results

## Seed Data

when user sends seed to /api/seed:
  create a1:
    name is 'Lindsay Walton'
    email is 'lindsay@example.com'
  save a1 as new Author
  create a2:
    name is 'Tom Cook'
    email is 'tom@example.com'
  save a2 as new Author
  create c1:
    name is 'Article'
  save c1 as new Category
  create c2:
    name is 'Tutorial'
  save c2 as new Category
  create c3:
    name is 'Case Study'
  save c3 as new Category
  create p1:
    title is 'Boost your conversion rate'
    body is 'Use A/B testing and funnel analysis to improve conversions by 20-30%.'
    excerpt is 'Proven strategies for improving site conversion rates.'
    image_url is 'https://images.unsplash.com/photo-1496128858413-b36217c2ce36?w=600&h=340&fit=crop'
    author is a1's id
    category is c1's id
  save p1 as new Post
  create p2:
    title is 'How to use search engine optimization'
    body is 'Modern SEO focuses on user intent, content quality, and Core Web Vitals.'
    excerpt is 'A deep dive into modern SEO techniques that work.'
    image_url is 'https://images.unsplash.com/photo-1547586696-ea22b4d4235d?w=600&h=340&fit=crop'
    author is a2's id
    category is c2's id
  save p2 as new Post
  create p3:
    title is 'Improve your customer experience'
    body is 'Companies investing in CX see 1.5x higher lifetime value. Start with journey mapping.'
    excerpt is 'Real results from companies that invested in CX design.'
    image_url is 'https://images.unsplash.com/photo-1492724441997-5dc865305da7?w=600&h=340&fit=crop'
    author is a1's id
    category is c3's id
  save p3 as new Post
  send back 'seeded'

# Frontend

page 'Blog' at '/':
  posts = []
  query = ''
  on page load:
    send nothing to '/api/seed'
    get posts from '/api/posts'
  section 'Hero' centered, padded:
    heading 'From the blog'
    text 'Learn how to grow your business with our expert advice.'
    link 'Write a new post →' to '/new'
  section 'Search' centered:
    'Search posts...' as text input saves to query
    button 'Search':
      get posts from '/api/search'
  section 'Posts' with style blog_grid:
    display posts as cards showing image_url, category, title, excerpt, author

page 'New Post' at '/new':
  title = ''
  body = ''
  excerpt = ''
  image_url = ''
  section 'Write a new post' centered, padded:
    heading 'Write a new post'
    text 'Share your thoughts with the world.'
  section 'Form' with style page_card:
    'Title' is a text input saved as title
    'Excerpt (short summary)' is a text input saved as excerpt
    'Image URL' is a text input saved as image_url
    'Body' is a text editor saved as body
    button 'Publish post':
      send title, body, excerpt and image_url as a new post to '/api/posts'
      title is ''
      body is ''
      excerpt is ''
      image_url is ''
      redirect to '/'
    link 'Cancel' to '/'

# Tests

test:
  can user view all posts

test:
  can user create a new post with title is 'Test Post' and body is 'Test body content'
  expect it succeeds
  expect response has id

test:
  can user create a post without a title

test:
  deleting a post should require login

test:
  can user view all authors
