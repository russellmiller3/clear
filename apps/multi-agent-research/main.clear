# Multi-Agent Research Assistant
#
# Showcase of every multi-agent orchestration pattern Clear supports:
#   1. Sequential chain — one agent calls the next (coordinator → specialist)
#   2. Parallel fan-out — `do these at the same time` (known arity)
#   3. Dynamic fan-out — `for each item: call 'Agent'` (runtime-sized lists)
#   4. Skill — reusable tool + instruction bundle shared by multiple agents
#
# One request → many AI calls → one combined answer.
# Pipelines are demoed in SYNTAX.md — left out here to keep auto-generated
# tests clean (pipelines emit their own evals).

build for web and javascript backend

database is local memory

create a Reports table:
  topic, required
  report, required
  created_at, auto

# === SPECIALIST AGENTS ===
# Streaming is the default for text agents. When a coordinator `call`s a
# streaming specialist, the compiler drains the generator into a string
# automatically — you never see the generator object.

agent 'Researcher' receives question:
  answer = ask claude 'Answer this question in 2-3 sentences' with question
  send back answer

agent 'Fact Checker' receives answer:
  verdict = ask claude 'Rate this answer 1-10 for factual accuracy. Return just the number.' with answer
  send back verdict

agent 'Sentiment Rater' receives answer:
  tone = ask claude 'Is this answer confident, cautious, or uncertain? One word.' with answer
  send back tone

# === SKILL: reusable tool + instructions bundle ===
# Skills merge into any agent via `uses skills:`. Instructions get prepended
# to the agent's prompt; listed tools get added to the agent's tool set.

skill 'Report Style':
  instructions:
    Use short paragraphs.
    Lead with the answer, follow with the reasoning.
    Never say 'As an AI'.

# === COORDINATOR AGENTS ===

# Pattern 2 — Parallel fan-out. Known arity: exactly two graders, both run
# at once and results meet back at the `create grade` record.
agent 'Grade Answer' receives answer:
  do these at the same time:
    accuracy = call 'Fact Checker' with answer
    tone = call 'Sentiment Rater' with answer
  create grade:
    accuracy is accuracy
    tone is tone
  send back grade

# Pattern 3 — Dynamic fan-out. Runtime-sized list of questions, each
# delegated to a specialist, results accumulated. The compiler emits a
# real for..of loop with a generator-drain IIFE around each streaming call.
agent 'Research All' receives questions:
  findings is an empty list
  for each question in questions:
    answer = call 'Researcher' with question
    add answer to findings
  send back findings

# Pattern 1 — Sequential chain. Top-level coordinator delegates in order.
# Each downstream call receives the result of the previous step. The input
# arrives as a list of comma-separated questions already split on the client.
agent 'Research Topic' receives questions:
  uses skills: 'Report Style'
  findings = call 'Research All' with questions
  report = ask claude 'Synthesize these findings into a final report' with findings
  send back report

# === ENDPOINTS ===

allow server to accept requests from frontend

when user sends request to /api/research:
  report = call 'Research Topic' with request's questions
  new_entry = save request as new Report with report is report
  send back new_entry

when user requests data from /api/reports:
  all_reports = get all Reports
  send back all_reports

# === FRONTEND ===

page 'Multi-Agent Research':
  on page load get reports from '/api/reports'
  heading 'Research Assistant'
  text 'Enter one or more questions separated by commas. A coordinator agent dispatches a specialist to research each question, grades every answer in parallel, and synthesizes a final report.'
  'Topics (comma-separated)' is a text input saved as a topic
  button 'Research':
    send topic as a new request to '/api/research'
    get reports from '/api/reports'
    topic is ''
  display reports as table showing topic, report, created_at
