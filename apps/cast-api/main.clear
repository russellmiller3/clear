build for javascript backend

# Cast API (Tier 4 acid test) -- Simplified version
# Rebuilds core Cast backend routes in Clear

# --- Data ---

create data shape Model:
  name is text, required
  type is text, required
  config is text
  created_at is timestamp, auto

create data shape Prediction:
  model_id is text, required
  input is text, required
  result is text
  created_at is timestamp, auto

create data shape ChatMessage:
  role is text, required
  content is text, required
  session_id is text, required
  created_at is timestamp, auto

create data shape SharedSheet:
  sheet_id is text, required, unique
  code is text, required
  title is text
  created_at is timestamp, auto

# --- Config ---

log every request
allow cross-origin requests

# --- Health ---

when user calls GET /api/health:
  send back 'ok'

# --- Models ---

when user calls GET /api/models:
  this endpoint requires login
  define all_models as: look up all records in Model table
  send back all_models

when user calls POST /api/models receiving model:
  this endpoint requires login
  validate model:
    name is text, required
    type is text, required
  define new_model as: save model as Model
  send back new_model status 201

when user calls GET /api/models/:id:
  this endpoint requires login
  define model as: look up records in Model table where id is incoming's id
  send back model

# --- Predictions ---

when user calls POST /api/predict receiving predict:
  this endpoint requires login
  validate predict:
    model_id is text, required
    input is text, required
  define prediction as: save predict as Prediction
  send back prediction status 201

# --- Chat ---

when user calls POST /api/chat receiving chat:
  this endpoint requires login
  validate chat:
    role is text, required
    content is text, required, min 1
    session_id is text, required
  define message as: save chat as ChatMessage
  send back message status 201

when user calls GET /api/chat/:session_id:
  this endpoint requires login
  define messages as: look up all records in ChatMessage table
  send back messages

# --- Share ---

when user calls POST /api/share receiving share:
  this endpoint requires login
  validate share:
    sheet_id is text, required
    code is text, required
  define shared as: save share as SharedSheet
  send back shared status 201

when user calls GET /api/share/:sheet_id:
  define shared as: look up all records in SharedSheet table
  send back shared

# --- Export ---

when user calls POST /api/export receiving export:
  this endpoint requires login
  validate export:
    format is text, required
  send back 'export started'
